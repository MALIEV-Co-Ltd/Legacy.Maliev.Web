@inject IStringLocalizer<ThreeDimensionalPrintingEstimateContent> Localizer

<section class="instant-quote__workflow"
         aria-labelledby="instant-quote-workflow-heading"
         aria-busy="@IsBusy.ToString().ToLowerInvariant()"
         data-workflow-state="@State.ToString().ToLowerInvariant()">
    <h2 id="instant-quote-workflow-heading">@Localizer["Instant Pricing"]</h2>

    <p id="instant-quote-status" aria-live="polite" aria-atomic="true">@StatusMessage</p>

    @if (VisibleSections.Upload)
    {
        <section data-workflow-upload aria-labelledby="instant-quote-upload-heading">
            <h3 id="instant-quote-upload-heading">@Localizer["Start by uploading a file"]</h3>
            <p>@Localizer["Upload and choose how you want your part to be printed. You'll know instantly how much does your part cost."]</p>
            <label for="instant-quote-files">@Localizer["Add file"]</label>
            <input id="instant-quote-files"
                   name="files"
                   type="file"
                   multiple
                   aria-describedby="instant-quote-upload-help instant-quote-status"
                   disabled="@IsBusy" />
            <p id="instant-quote-upload-help">@Localizer["Drop your 3D file here"] — @Localizer["or click to browse"]</p>
        </section>
    }

    @if (VisibleSections.Error)
    {
        <p role="alert">@Localizer["The file could not be uploaded. Try again."]</p>
    }

    @if (VisibleSections.Viewer)
    {
        <section data-workflow-viewer aria-labelledby="instant-quote-viewer-heading">
            <h3 id="instant-quote-viewer-heading">@Localizer["3D preview"]</h3>
            <p>@Localizer["The uploaded part preview will appear here."]</p>
            <button type="button">@Localizer["Reset view"]</button>
            <button type="button">@Localizer["Fit to view"]</button>
        </section>
    }

    @if (VisibleSections.Parts)
    {
        <section data-workflow-parts aria-labelledby="instant-quote-parts-heading">
            <h3 id="instant-quote-parts-heading">@Localizer["Parts"]</h3>
            <p>@Localizer["Uploaded parts will appear here."]</p>
        </section>
    }

    @if (VisibleSections.Configuration)
    {
        <section data-workflow-configuration aria-labelledby="instant-quote-configuration-heading">
            <h3 id="instant-quote-configuration-heading">@Localizer["Part configuration"]</h3>

            <section data-workflow-dfm-status aria-labelledby="instant-quote-dfm-heading">
                <h4 id="instant-quote-dfm-heading">@Localizer["Design-for-manufacturing checks"]</h4>
                <p>@Localizer["You'll get a feedback from us if your design has potential problems."]</p>
            </section>

            <fieldset data-workflow-material-color-quantity disabled>
                <legend>@Localizer["Settings"]</legend>
                <label for="instant-quote-material">@Localizer["Material"]</label>
                <select id="instant-quote-material" name="material">
                    <option>@Localizer["Material"]</option>
                </select>
                <label for="instant-quote-color">@Localizer["Color"]</label>
                <select id="instant-quote-color" name="color">
                    <option>@Localizer["Color"]</option>
                </select>
                <label for="instant-quote-quantity">@Localizer["Quantity"]</label>
                <input id="instant-quote-quantity" name="quantity" type="number" min="1" value="1" />
            </fieldset>

            <dl>
                <div data-workflow-part-price>
                    <dt>@Localizer["Unit price"]</dt>
                    <dd>—</dd>
                </div>
                <div data-workflow-order-summary>
                    <dt>@Localizer["Total"]</dt>
                    <dd>—</dd>
                </div>
                <div data-workflow-lead-time>
                    <dt>@Localizer["Lead time"]</dt>
                    <dd>—</dd>
                </div>
            </dl>

            <button type="button">@Localizer["Back"]</button>
            <button type="button" disabled>@Localizer["Review"]</button>
        </section>
    }

    @if (VisibleSections.Review)
    {
        <section data-workflow-review aria-labelledby="instant-quote-review-heading">
            <h3 id="instant-quote-review-heading">@Localizer["Review"]</h3>
            <p>@Localizer["Price and lead time are estimates and may change after our engineers review your part for manufacturability."]</p>
            <button type="button">@Localizer["Back"]</button>
            <button type="button" disabled>@Localizer["Customer details"]</button>
        </section>
    }

    @if (VisibleSections.CustomerDetails)
    {
        <section data-workflow-customer-details aria-labelledby="instant-quote-customer-heading">
            <h3 id="instant-quote-customer-heading">@Localizer["Customer details"]</h3>
            <fieldset disabled>
                <legend>@Localizer["Your information is safe"]</legend>
                <label for="instant-quote-email">@Localizer["Email"]</label>
                <input id="instant-quote-email" name="email" type="email" autocomplete="email" />
            </fieldset>
            <button type="button">@Localizer["Back"]</button>
            <button type="button" disabled>@Localizer["Submit"]</button>
        </section>
    }

    @if (VisibleSections.Submitted)
    {
        <section data-workflow-submitted aria-labelledby="instant-quote-submitted-heading">
            <h3 id="instant-quote-submitted-heading">@Localizer["Ready for manufacturing"]</h3>
            <p>@Localizer["We will get back to you with a quotation"]</p>
        </section>
    }
</section>
