@using Microsoft.AspNetCore.Components.Forms
@inject IStringLocalizer<ThreeDimensionalPrintingEstimateContent> Localizer

<section class="instant-quote__workflow"
         aria-labelledby="instant-quote-workflow-heading"
         aria-busy="@IsBusy.ToString().ToLowerInvariant()"
         data-workflow-state="@State.ToString().ToLowerInvariant()">
    <h2 id="instant-quote-workflow-heading">@Localizer["Instant Pricing"]</h2>

    <p id="instant-quote-status" aria-live="polite" aria-atomic="true">@StatusMessage</p>
    <p @ref="previewStatus" data-workflow-preview-status role="status" aria-live="polite">@PreviewStatusMessage</p>

    @if (VisibleSections.Upload)
    {
        <section data-workflow-upload aria-labelledby="instant-quote-upload-heading">
            <h3 id="instant-quote-upload-heading">@Localizer["Start by uploading a file"]</h3>
            <p>@Localizer["Upload and choose how you want your part to be printed. You'll know instantly how much does your part cost."]</p>
            <label for="instant-quote-files">@Localizer["Add file"]</label>
            <InputFile id="instant-quote-files"
                       @ref="fileInput"
                       name="files"
                       OnChange="UploadFilesAsync"
                       multiple
                       accept=".stl,.obj,.3mf,.glb,.gltf,.stp,.step,.igs,.iges"
                       aria-describedby="instant-quote-upload-help instant-quote-status"
                       disabled="@IsBusy" />
            <p id="instant-quote-upload-help">@Localizer["Drop your 3D file here"] — @Localizer["or click to browse"]</p>

            @foreach (var upload in Uploads)
            {
                <article data-workflow-upload-item aria-labelledby="upload-name-@upload.LocalId">
                    <h4 id="upload-name-@upload.LocalId">@upload.DisplayFileName</h4>
                    <p aria-live="polite">@UploadStatus(upload.Status)</p>
                    @if (upload.Status is InstantQuotationWorkflowUploadStatus.Uploading)
                    {
                        <progress aria-label="@Localizer["Upload progress"]"></progress>
                        <button type="button" @onclick="() => CancelUpload(upload.LocalId)">@Localizer["Cancel"]</button>
                    }
                    else if (upload.Status is InstantQuotationWorkflowUploadStatus.Error or InstantQuotationWorkflowUploadStatus.Cancelled)
                    {
                        <button type="button" @onclick="() => RetryUploadAsync(upload.LocalId)">@Localizer["Try again"]</button>
                    }
                </article>
            }
        </section>
    }

    @if (VisibleSections.Error)
    {
        <p role="alert">@Localizer["The file could not be uploaded. Try again."]</p>
    }

    @if (VisibleSections.Viewer)
    {
        <section data-workflow-viewer aria-labelledby="instant-quote-viewer-heading">
            <h3 id="instant-quote-viewer-heading">@Localizer["3D preview"]</h3>
            <p id="instant-quote-preview-help">@Localizer["The uploaded part preview will appear here."]</p>
            <canvas @ref="previewCanvas"
                    tabindex="0"
                    aria-label="@Localizer["Interactive 3D part preview"]"
                    aria-describedby="instant-quote-preview-help"></canvas>
            <button type="button" @onclick="ResetPreviewAsync">@Localizer["Reset view"]</button>
            <button type="button" @onclick="FitPreviewAsync">@Localizer["Fit to view"]</button>
            <button type="button" @onclick="FullscreenPreviewAsync">@Localizer["Fullscreen"]</button>
        </section>
    }

    @if (VisibleSections.Parts)
    {
        <section data-workflow-parts data-workflow-part-list aria-labelledby="instant-quote-parts-heading">
            <h3 id="instant-quote-parts-heading">@Localizer["Parts"]</h3>
            @foreach (var part in Parts)
            {
                <article data-workflow-part data-part-id="@part.PartId">
                    <h4>@part.DisplayFileName</h4>
                    <button type="button" @onclick="() => SelectPreviewAsync(part.PartId)">@Localizer["View"]</button>
                    <button type="button" @onclick="() => RemovePartAsync(part.PartId)">@Localizer["Remove"]</button>
                </article>
            }
        </section>
    }

    @if (VisibleSections.Configuration)
    {
        <section data-workflow-configuration aria-labelledby="instant-quote-configuration-heading">
            <h3 id="instant-quote-configuration-heading">@Localizer["Part configuration"]</h3>

            <section data-workflow-dfm-status aria-labelledby="instant-quote-dfm-heading">
                <h4 id="instant-quote-dfm-heading">@Localizer["Design-for-manufacturing checks"]</h4>
                <p>@Localizer["You'll get a feedback from us if your design has potential problems."]</p>
            </section>

            @foreach (var part in Parts)
            {
                <fieldset data-workflow-material-color-quantity data-workflow-material-picker>
                    <legend>@part.DisplayFileName — @Localizer["Settings"]</legend>
                    <label for="material-@part.PartId">@Localizer["Material"]</label>
                    <select id="material-@part.PartId"
                            name="material"
                            value="@part.Configuration.MaterialKey"
                            @onchange="args => ChangeMaterialAsync(part.PartId, args)">
                        @foreach (var material in Materials)
                        {
                            <option value="@material.Key">@material.DisplayName</option>
                        }
                    </select>
                    <label for="color-@part.PartId">@Localizer["Color"]</label>
                    <select id="color-@part.PartId"
                            name="color"
                            value="@part.Configuration.Color"
                            @onchange="args => ChangeColorAsync(part.PartId, args)">
                        @foreach (var color in GetColors(part.Configuration.MaterialKey))
                        {
                            <option value="@color">@color</option>
                        }
                    </select>
                    <label for="quantity-@part.PartId">@Localizer["Quantity"]</label>
                    <input id="quantity-@part.PartId"
                           name="quantity"
                           type="number"
                           min="1"
                           max="1000"
                           value="@part.Configuration.Quantity"
                           @onchange="args => ChangeQuantityAsync(part.PartId, args)" />
                </fieldset>

                <dl data-workflow-part-price data-workflow-part-pricing>
                    <div>
                        <dt>@Localizer["Unit price"]</dt>
                        <dd>@Money(part.Quote?.UnitPrice)</dd>
                    </div>
                    <div>
                        <dt>@Localizer["Subtotal"]</dt>
                        <dd>@Money(part.Quote?.Subtotal)</dd>
                    </div>
                    @if (part.Quote is not null)
                    {
                        @foreach (var tier in part.Quote.Tiers)
                        {
                            <div data-workflow-price-tier>
                                <dt>@Localizer["Quantity"] @tier.MinQuantity</dt>
                                <dd>@Money(tier.UnitPrice)</dd>
                            </div>
                        }
                    }
                </dl>
            }

            <dl data-workflow-order-summary data-workflow-order-total>
                <div><dt>@Localizer["Subtotal"]</dt><dd>@Money(OrderQuote?.ItemsSubtotal)</dd></div>
                <div><dt>@Localizer["Shipping"]</dt><dd>@Money(OrderQuote?.ShippingCost)</dd></div>
                <div><dt>@Localizer["VAT"]</dt><dd>@Money(OrderQuote?.Vat)</dd></div>
                <div><dt>@Localizer["Total"]</dt><dd>@Money(OrderQuote?.FinalOrderPrice)</dd></div>
                <div data-workflow-lead-time>
                    <dt>@Localizer["Lead time"]</dt>
                    <dd>@LeadTime</dd>
                </div>
            </dl>

            <button type="button" disabled>@Localizer["Back"]</button>
            <button type="button" disabled>@Localizer["Review"]</button>
        </section>
    }

    @if (VisibleSections.Review)
    {
        <section data-workflow-review aria-labelledby="instant-quote-review-heading">
            <h3 id="instant-quote-review-heading">@Localizer["Review"]</h3>
            <p>@Localizer["Price and lead time are estimates and may change after our engineers review your part for manufacturability."]</p>
            <button type="button" disabled>@Localizer["Back"]</button>
            <button type="button" disabled>@Localizer["Customer details"]</button>
        </section>
    }

    @if (VisibleSections.CustomerDetails)
    {
        <section data-workflow-customer-details aria-labelledby="instant-quote-customer-heading">
            <h3 id="instant-quote-customer-heading">@Localizer["Customer details"]</h3>
            <fieldset disabled>
                <legend>@Localizer["Your information is safe"]</legend>
                <label for="instant-quote-email">@Localizer["Email"]</label>
                <input id="instant-quote-email" name="email" type="email" autocomplete="email" />
            </fieldset>
            <button type="button" disabled>@Localizer["Back"]</button>
            <button type="button" disabled>@Localizer["Submit"]</button>
        </section>
    }

    @if (VisibleSections.Submitted)
    {
        <section data-workflow-submitted aria-labelledby="instant-quote-submitted-heading">
            <h3 id="instant-quote-submitted-heading">@Localizer["Ready for manufacturing"]</h3>
            <p>@Localizer["We will get back to you with a quotation"]</p>
        </section>
    }
</section>
