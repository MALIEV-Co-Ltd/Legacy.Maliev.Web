@page "/Member/Account/Manage/ChangePassword"
@using Legacy.Maliev.Web.Infrastructure
@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.RateLimiting
@attribute [Authorize]
@attribute [EnableRateLimiting("account")]
@inject IHttpContextAccessor HttpContextAccessor
@inject IAccountSessionManager SessionManager
@inject IAntiforgery Antiforgery
@inject IStringLocalizer<MemberChangePasswordContent> Localizer

<PageTitle>@Localizer["Change password | MALIEV"]</PageTitle><HeadContent><meta name="robots" content="noindex,follow" /></HeadContent>
<div data-migration-route-owner="blazor-static-ssr"><MemberWorkspaceShell><section class="maliev-section" aria-labelledby="member-change-password-title"><form method="post" action="/member/account/manage/changepassword?handler=ChangePassword" class="maliev-panel maliev-form" data-password-confirmation data-password-mismatch="@Localizer["Passwords do not match."]">@if (tokens is not null) { <input type="hidden" name="@tokens.FormFieldName" value="@tokens.RequestToken" /> }<MemberChangePasswordContent Model="MemberChangePasswordDisplayModel.Empty" /></form></section></MemberWorkspaceShell></div>

@code {
    private AntiforgeryTokenSet? tokens;
    protected override async Task OnInitializedAsync()
    {
        var context = HttpContextAccessor.HttpContext ?? throw new InvalidOperationException("Static SSR requires an active HTTP context.");
        _ = await SessionManager.GetAccessTokenAsync(context, context.RequestAborted);
        tokens = Antiforgery.GetAndStoreTokens(context);
    }
}
