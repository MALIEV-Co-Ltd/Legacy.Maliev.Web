@inject IStringLocalizer<MemberChangePasswordContent> Localizer

<div data-migration-component="member-change-password-content">
    <div class="maliev-section-header">
        <p class="maliev-eyebrow">@Localizer["Customer account"]</p>
        <h1 id="member-change-password-title">@Localizer["Change password"]</h1>
        <p id="member-change-password-guidance">@Localizer["All signed-in sessions will be revoked after this change."]</p>
    </div>
    @if (Model.Errors.Count > 0)
    {
        <div class="field-validation-error" role="alert">
            <ul>
                @foreach (var error in Model.Errors)
                {
                    <li>@Localizer[error]</li>
                }
            </ul>
        </div>
    }
    <div class="maliev-form-field">
        <label for="member-current-password">@Localizer["Current password"]</label>
        <input id="member-current-password" type="password" name="CurrentPassword" autocomplete="current-password" required maxlength="1024" aria-describedby="member-change-password-guidance" />
    </div>
    <div class="maliev-form-field">
        <label for="member-new-password">@Localizer["New password"]</label>
        <input id="member-new-password" type="password" name="NewPassword" autocomplete="new-password" required minlength="6" maxlength="1024" aria-describedby="member-change-password-guidance" data-password-primary />
    </div>
    <div class="maliev-form-field">
        <label for="member-confirm-password">@Localizer["Confirm new password"]</label>
        <input id="member-confirm-password" type="password" name="ConfirmPassword" autocomplete="new-password" required maxlength="1024" aria-describedby="member-change-password-guidance" data-password-confirm />
    </div>
    <button type="submit" class="maliev-button">@Localizer["Change password"]</button>
</div>

@code {
    [Parameter]
    public MemberChangePasswordDisplayModel Model { get; set; } = MemberChangePasswordDisplayModel.Empty;
}
