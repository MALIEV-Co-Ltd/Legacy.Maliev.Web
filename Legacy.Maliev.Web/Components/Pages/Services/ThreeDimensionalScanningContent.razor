@using System.Globalization
@using Legacy.Maliev.Web.Components.Shared

<main class="service-page" data-migration-component="three-dimensional-scanning-content" data-migration-route-owner="@RouteOwner">
    <ServiceBreadcrumb ServiceKey="3D Scanning" />
    <section class="service-hero" aria-labelledby="scanning-title">
        <img class="service-hero-media" src="/src/images/services/scanning/scanning-hero.webp" width="1672" height="941" loading="eager" fetchpriority="high" decoding="async" alt="@T("Structured-light 3D scanning of a cast aluminum housing", "การสแกน 3D แบบ Structured Light บนตัวเรือนอะลูมิเนียมหล่อ")" />
        <div class="service-container service-hero-copy">
            <p class="service-eyebrow">@T("In-House & Onsite 3D Scanning", "บริการสแกน 3D ในสถานที่และนอกสถานที่")</p>
            <h1 id="scanning-title">@T("3D Scanning, Reverse Engineering, and Deviation Analysis", "รับสแกน 3D, Reverse Engineering และ Deviation Analysis")</h1>
            <p class="service-hero-lead">@T("Capture real objects as digital geometry, rebuild editable CAD when needed, or compare a manufactured part with nominal CAD. We help define the correct deliverable before scanning begins.", "MALIEV รับสแกน 3D ทั้งในสถานที่และนอกสถานที่ เพื่อแปลงวัตถุจริงเป็นข้อมูลดิจิทัล สร้าง CAD ที่แก้ไขได้ หรือเปรียบเทียบชิ้นงานกับ CAD ต้นแบบ โดยช่วยกำหนดผลส่งมอบก่อนเริ่มงาน")</p>
            <ul class="service-hero-points"><li><i class="fas fa-check-circle" aria-hidden="true"></i>@T("In-house and onsite", "ในสถานที่และนอกสถานที่")</li><li><i class="fas fa-check-circle" aria-hidden="true"></i>@T("Raw mesh to editable CAD", "จาก Raw Mesh สู่ CAD")</li><li><i class="fas fa-check-circle" aria-hidden="true"></i>@T("CAD comparison and color maps", "เปรียบเทียบ CAD และแผนที่สี")</li></ul>
            <div class="service-actions">
                <a class="service-button service-button-primary" href="/Quotation?item=3D-Scanning">@T("Request a Scanning Quote", "ขอใบเสนอราคาสแกน 3D") <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
                <a class="service-button service-button-secondary" href="/Contact">@T("Plan an Onsite Scan", "วางแผนสแกนนอกสถานที่")</a>
            </div>
        </div>
    </section>

    <section class="service-quick"><div class="service-container service-quick-grid">
        <article><i class="fas fa-camera" aria-hidden="true"></i><div><h2>@T("Raw capture", "ข้อมูลสแกน")</h2><p>@T("Point/mesh data for visualization, archiving, and downstream work.", "ข้อมูลจุดหรือเมชสำหรับแสดงผล เก็บถาวร และงานต่อยอด")</p></div></article>
        <article><i class="fas fa-drafting-compass" aria-hidden="true"></i><div><h2>@T("Reverse engineering", "Reverse Engineering")</h2><p>@T("Reconstructed surfaces and features when editable CAD is required.", "สร้างพื้นผิวและฟีเจอร์ใหม่เมื่อต้องการ CAD ที่แก้ไขได้")</p></div></article>
        <article><i class="fas fa-chart-area" aria-hidden="true"></i><div><h2>@T("Deviation analysis", "Deviation Analysis")</h2><p>@T("Compare scan data with nominal CAD to visualize differences.", "เปรียบเทียบข้อมูลสแกนกับ CAD เพื่อแสดงความแตกต่าง")</p></div></article>
        <article><i class="fas fa-truck" aria-hidden="true"></i><div><h2>@T("Onsite service", "บริการนอกสถานที่")</h2><p>@T("For large, fixed, fragile, or impractical-to-transport objects.", "สำหรับวัตถุขนาดใหญ่ ติดตั้งอยู่ เปราะบาง หรือขนย้ายไม่สะดวก")</p></div></article>
    </div></section>

    <section id="scanning-selection-guide" class="service-section"><div class="service-container"><header class="service-heading center"><p class="service-eyebrow">@T("Choose the Deliverable First", "เลือกผลลัพธ์ก่อนสแกน")</p><h2>@T("Do you need a raw scan, reverse-engineered CAD, or deviation analysis?", "ต้องการ Raw Scan, CAD จาก Reverse Engineering หรือ Deviation Analysis?")</h2><p>@T("Scanning is data capture—not an automatic one-click conversion into every file type. The right workflow starts with what you need to do after the scan.", "การสแกนคือการเก็บข้อมูล ไม่ใช่การแปลงอัตโนมัติเป็นทุกชนิดไฟล์ในคลิกเดียว ขั้นตอนที่ถูกต้องเริ่มจากสิ่งที่ต้องนำข้อมูลไปใช้")</p></header><div class="service-card-grid">
        <article class="service-card service-card-visual"><img class="service-card-media" src="/src/images/services/scanning/cards/scanning-card-raw-mesh.webp" loading="lazy" width="960" height="640" alt="@T("A scanned cast housing shown as a digital mesh beside the physical part", "ตัวเรือนหล่อที่สแกนเป็นดิจิทัลเมชวางคู่กับชิ้นงานจริง")" /><div class="service-card-body"><h3>@T("Choose a raw or cleaned mesh when…", "เลือก Raw หรือ Cleaned Mesh เมื่อ…")</h3><p>@T("You need visualization, digital preservation, approximate measurements within the agreed scan capability, a reference for sculpting, or input for later processing. Typical outputs are STL, OBJ, or PLY.", "ต้องการแสดงผล เก็บข้อมูลดิจิทัล วัดในขอบเขตที่ตกลง ใช้อ้างอิงงานปั้น หรือเป็นข้อมูลสำหรับขั้นต่อไป ไฟล์ทั่วไปคือ STL, OBJ หรือ PLY")</p></div></article>
        <article class="service-card service-card-visual"><img class="service-card-media" src="/src/images/services/scanning/cards/scanning-card-reverse-engineering.webp" loading="lazy" width="960" height="640" alt="@T("An engineer rebuilding a scanned mechanical part as editable CAD", "วิศวกรสร้างชิ้นส่วนเครื่องกลจากข้อมูลสแกนเป็น CAD ที่แก้ไขได้")" /><div class="service-card-body"><h3>@T("Choose reverse engineering when…", "เลือก Reverse Engineering เมื่อ…")</h3><p>@T("You need editable manufacturing geometry, design changes, replacement-part drawings, mating interfaces, or a CAD model suitable for downstream engineering. Outputs may include STEP or IGES as agreed.", "ต้องการรูปทรงสำหรับผลิตที่แก้ไขได้ ปรับแบบ ทำอะไหล่ สร้างผิวประกอบ หรือใช้ในงานวิศวกรรมต่อไป ไฟล์อาจเป็น STEP หรือ IGES ตามขอบเขต")</p></div></article>
        <article class="service-card service-card-visual"><img class="service-card-media" src="/src/images/services/scanning/cards/scanning-card-deviation-analysis.webp" loading="lazy" width="960" height="640" alt="@T("A color deviation map comparing a scanned impeller with nominal CAD", "แผนที่สีเปรียบเทียบใบพัดที่สแกนกับ CAD ต้นแบบ")" /><div class="service-card-body"><h3>@T("Choose deviation analysis when…", "เลือก Deviation Analysis เมื่อ…")</h3><p>@T("You have nominal CAD and need to visualize where a manufactured, worn, bent, or modified object differs. The agreed output can include aligned comparison views and color-map reporting.", "มี CAD ต้นแบบและต้องการดูตำแหน่งที่ชิ้นงานผลิต สึก งอ หรือดัดแปลงแตกต่างกัน ผลส่งมอบอาจเป็นภาพเปรียบเทียบและรายงานแผนที่สี")</p></div></article>
    </div></div></section>

    <section id="scanning-workflow" class="service-section service-section-soft"><div class="service-container service-split reverse"><img class="service-split-image" src="/src/images/services/scanning/scanning-workflow.webp" loading="lazy" width="1776" height="887" alt="@T("Physical part, raw scan mesh, reverse-engineered CAD, and deviation color map", "ชิ้นงานจริง เมชจากการสแกน CAD จาก Reverse Engineering และแผนที่สีความคลาดเคลื่อน")" /><div class="service-copy"><p class="service-eyebrow">@T("A Staged Workflow", "ขั้นตอนที่แยกชัดเจน")</p><h2>@T("What happens at each 3D scanning stage?", "แต่ละขั้นตอนของงานสแกน 3D ทำอะไร?")</h2><p>@T("Each stage adds work and a different kind of information. Ordering only the stage you need avoids paying for unnecessary modeling while ensuring the output is usable.", "แต่ละขั้นเพิ่มงานและข้อมูลคนละประเภท การเลือกเฉพาะขั้นที่จำเป็นช่วยลดงานเกินความต้องการและทำให้ไฟล์ใช้งานได้จริง")</p></div></div></section>

    <section class="service-section"><div class="service-container"><ol class="service-process">
        <li><h3>@T("Plan and prepare", "วางแผนและเตรียม")</h3><p>@T("Define purpose, critical areas, object size, surface, access, environment, target files, and whether nominal CAD exists.", "กำหนดวัตถุประสงค์ จุดสำคัญ ขนาด ผิว การเข้าถึง สภาพแวดล้อม ไฟล์ที่ต้องการ และ CAD ต้นแบบ")</p></li>
        <li><h3>@T("Capture and register", "สแกนและจัดแนว")</h3><p>@T("Collect overlapping views with targets or geometry references, then align passes into a common coordinate system.", "เก็บภาพสแกนซ้อนทับกันด้วยเป้าหรือรูปทรงอ้างอิง แล้วจัดแนวให้อยู่ในพิกัดเดียวกัน")</p></li>
        <li><h3>@T("Clean and mesh", "ทำความสะอาดและสร้างเมช")</h3><p>@T("Remove unrelated data and noise, merge suitable regions, and fill only appropriate gaps without inventing critical hidden geometry.", "ลบข้อมูลเกินและสัญญาณรบกวน รวมพื้นที่ที่เหมาะสม และปิดช่องว่างเฉพาะที่ควรทำ โดยไม่สร้างรูปทรงสำคัญที่มองไม่เห็นขึ้นเอง")</p></li>
        <li><h3>@T("Engineer or compare", "สร้าง CAD หรือเปรียบเทียบ")</h3><p>@T("Reconstruct agreed CAD features or align the scan with nominal CAD for deviation analysis and reporting.", "สร้างฟีเจอร์ CAD ตามขอบเขต หรือจัดแนวข้อมูลสแกนกับ CAD ต้นแบบเพื่อวิเคราะห์และรายงาน")</p></li>
    </ol></div></section>

    <section id="scanning-service-modes" class="service-section service-section-dark"><div class="service-container"><header class="service-heading"><p class="service-eyebrow">@T("In-House or Onsite", "ในสถานที่หรือนอกสถานที่")</p><h2>@T("When is onsite 3D scanning the better choice?", "เมื่อใดควรเลือกบริการสแกนนอกสถานที่?")</h2><p>@T("Onsite scanning is useful when equipment, vehicles, architecture, tooling, sculptures, or assemblies are too large, fixed, fragile, valuable, or disruptive to transport.", "บริการนอกสถานที่เหมาะกับเครื่องจักร ยานพาหนะ สถาปัตยกรรม แม่พิมพ์ ประติมากรรม หรือชุดประกอบที่ใหญ่ ติดตั้งอยู่ เปราะบาง มีมูลค่า หรือขนย้ายกระทบงาน")</p></header><div class="service-card-grid">
        <article class="service-card service-card-visual"><img class="service-card-media" src="/src/images/services/scanning/cards/scanning-card-site-access.webp" loading="lazy" width="960" height="640" alt="@T("A technician scanning a large fixed pump with safe working clearance", "ช่างกำลังสแกนปั๊มขนาดใหญ่ที่ติดตั้งอยู่โดยมีพื้นที่ทำงานปลอดภัย")" /><div class="service-card-body"><h3>@T("Site access", "การเข้าถึงพื้นที่")</h3><p>@T("We need safe working clearance and line of sight around the subject. Barriers, height, confined spaces, live machinery, traffic, and production schedules affect feasibility.", "ต้องมีพื้นที่ทำงานปลอดภัยและมองเห็นรอบวัตถุ สิ่งกีดขวาง ความสูง ที่อับ เครื่องจักรทำงาน การจราจร และตารางผลิตมีผลต่อความเป็นไปได้")</p></div></article>
        <article class="service-card service-card-visual"><img class="service-card-media" src="/src/images/services/scanning/cards/scanning-card-environment.webp" loading="lazy" width="960" height="640" alt="@T("A controlled-light enclosure protecting an industrial 3D scan from reflections", "พื้นที่ควบคุมแสงสำหรับป้องกันเงาสะท้อนระหว่างสแกนชิ้นงานอุตสาหกรรม")" /><div class="service-card-body"><h3>@T("Environment", "สภาพแวดล้อม")</h3><p>@T("Changing sunlight, rain, dust, vibration, heat, wind, reflections, and object movement can reduce capture quality or require controls and repeat passes.", "แสงแดดเปลี่ยน ฝน ฝุ่น การสั่น ความร้อน ลม เงาสะท้อน และการเคลื่อนไหวอาจลดคุณภาพหรือต้องควบคุมและสแกนซ้ำ")</p></div></article>
        <article class="service-card service-card-visual"><img class="service-card-media" src="/src/images/services/scanning/cards/scanning-card-previsit-planning.webp" loading="lazy" width="960" height="640" alt="@T("An engineer reviewing site photos, dimensions, drawings, and PPE before a visit", "วิศวกรตรวจรูปสถานที่ ขนาด แบบงาน และ PPE ก่อนเข้าพื้นที่")" /><div class="service-card-body"><h3>@T("Pre-visit planning", "วางแผนก่อนเข้าพื้นที่")</h3><p>@T("Share photos, dimensions, location, access restrictions, required PPE, operating conditions, target deliverables, and nominal CAD before scheduling.", "ส่งรูป ขนาด สถานที่ ข้อจำกัดการเข้าถึง PPE สภาพการทำงาน ผลลัพธ์ที่ต้องการ และ CAD ก่อนนัดหมาย")</p></div></article>
    </div></div></section>

    <section id="scanning-preparation" class="service-section"><div class="service-container"><header class="service-heading center"><p class="service-eyebrow">@T("Prepare for Scanning", "เตรียมงานก่อนสแกน")</p><h2>@T("How should an object be prepared?", "ควรเตรียมวัตถุอย่างไร?")</h2></header><div class="service-card-grid">
        <article class="service-card service-card-visual"><img class="service-card-media" src="/src/images/services/scanning/cards/scanning-card-define-outcome.webp" loading="lazy" width="960" height="640" alt="@T("A mechanical part and drawing arranged to identify critical scan dimensions", "ชิ้นส่วนเครื่องกลและแบบงานสำหรับกำหนดขนาดสำคัญในการสแกน")" /><div class="service-card-body"><h3>@T("Define the outcome", "กำหนดผลลัพธ์")</h3><p>@T("Identify critical dimensions, interfaces, areas of interest, intended file use, reference coordinate system, and acceptable exclusions.", "ระบุขนาดสำคัญ ผิวประกอบ พื้นที่สนใจ การใช้ไฟล์ ระบบพิกัดอ้างอิง และส่วนที่ยอมรับให้ขาดได้")</p></div></article>
        <article class="service-card service-card-visual"><img class="service-card-media" src="/src/images/services/scanning/cards/scanning-card-clean-stabilize.webp" loading="lazy" width="960" height="640" alt="@T("Gloved hands cleaning and supporting a mechanical part before scanning", "มือสวมถุงมือกำลังทำความสะอาดและรองรับชิ้นงานก่อนสแกน")" /><div class="service-card-body"><h3>@T("Clean and stabilize", "ทำความสะอาดและทำให้นิ่ง")</h3><p>@T("Remove loose dirt and unnecessary attachments where safe. Support flexible items, stop moving mechanisms, and maintain one stable shape during capture.", "ลบฝุ่นหลวมและอุปกรณ์ที่ไม่จำเป็นอย่างปลอดภัย รองรับชิ้นงานยืดหยุ่น หยุดกลไก และรักษารูปทรงให้นิ่งตลอดการสแกน")</p></div></article>
        <article class="service-card service-card-visual"><img class="service-card-media" src="/src/images/services/scanning/cards/scanning-card-difficult-surfaces.webp" loading="lazy" width="960" height="640" alt="@T("A reflective component partly treated with removable matte scanning spray and targets", "ชิ้นงานผิวเงาที่เตรียมบางส่วนด้วยสเปรย์สแกนแบบด้านและเป้าสแกน")" /><div class="service-card-body"><h3>@T("Prepare difficult surfaces", "เตรียมผิวที่สแกนยาก")</h3><p>@T("Reflective, transparent, translucent, or very dark surfaces may need controlled lighting, targets, or temporary removable scanning spray with owner approval.", "ผิวเงา ใส โปร่งแสง หรือดำมากอาจต้องควบคุมแสง ติดเป้า หรือใช้สเปรย์สแกนแบบล้างออกได้เมื่อเจ้าของอนุมัติ")</p></div></article>
    </div></div></section>

    <section id="scanning-limitations" class="service-section service-section-soft"><div class="service-container"><header class="service-heading center"><p class="service-eyebrow">@T("What Scans Well—and What Does Not", "สิ่งที่สแกนได้ดีและข้อจำกัด")</p><h2>@T("3D scanning needs line of sight and a stable surface", "การสแกน 3D ต้องมองเห็นผิวและวัตถุต้องคงที่")</h2></header><div class="service-table-wrap"><table class="service-table"><thead><tr><th>@T("Condition", "ลักษณะวัตถุ")</th><th>@T("What usually happens", "ผลที่มักเกิด")</th><th>@T("Possible preparation", "แนวทางเตรียม")</th></tr></thead><tbody>
        <tr><td>@T("Matte, rigid, textured surfaces", "ผิวด้าน แข็ง และมีรายละเอียด")</td><td>@T("Usually provide stable visual geometry for registration and capture.", "มักให้ข้อมูลรูปทรงที่เสถียรต่อการจัดแนวและเก็บผิว")</td><td>@T("Clean, expose critical areas, and keep the object still.", "ทำความสะอาด เปิดจุดสำคัญ และรักษาให้นิ่ง")</td></tr>
        <tr><td>@T("Shiny, mirror-like, transparent, or translucent", "ผิวเงากระจก ใส หรือโปร่งแสง")</td><td>@T("Light reflects or passes through, causing missing, distorted, or noisy data.", "แสงสะท้อนหรือทะลุผ่าน ทำให้ข้อมูลขาด บิดเบือน หรือมีสัญญาณรบกวน")</td><td>@T("Controlled lighting, removable matte spray, targets, or another measurement method after review.", "ควบคุมแสง ใช้สเปรย์ผิวด้านล้างออก ติดเป้า หรือเลือกวิธีวัดอื่นหลังประเมิน")</td></tr>
        <tr><td>@T("Deep holes, narrow gaps, undercuts, and internal passages", "รูลึก ช่องแคบ อันเดอร์คัต และทางเดินภายใน")</td><td>@T("The scanner cannot capture surfaces it cannot see; shadowed geometry may remain incomplete.", "เครื่องสแกนเก็บผิวที่มองไม่เห็นไม่ได้ รูปทรงในเงาหรือภายในอาจไม่ครบ")</td><td>@T("Multiple angles, partial disassembly when approved, complementary measurement, or explicitly excluded regions.", "สแกนหลายมุม ถอดบางส่วนเมื่ออนุมัติ ใช้วิธีวัดเสริม หรือระบุส่วนที่ไม่รวม")</td></tr>
        <tr><td>@T("Soft, flexible, moving, or hot objects", "วัตถุนิ่ม ยืดหยุ่น เคลื่อนไหว หรือร้อน")</td><td>@T("Shape changes between views and registration becomes unreliable or unsafe.", "รูปทรงเปลี่ยนระหว่างภาพ ทำให้จัดแนวไม่น่าเชื่อถือหรือไม่ปลอดภัย")</td><td>@T("Stabilize safely, cool or stop equipment, define one operating state, or use a different capture strategy.", "ทำให้นิ่งและปลอดภัย ลดอุณหภูมิหรือหยุดเครื่อง กำหนดสภาพเดียว หรือเลือกวิธีอื่น")</td></tr>
        <tr><td>@T("Very small edges, threads, engraving, or surface texture", "ขอบเล็กมาก เกลียว ตัวสลัก หรือผิวละเอียด")</td><td>@T("Features below the practical sampling and optical limit may soften or disappear.", "รายละเอียดต่ำกว่าขีดจำกัดการเก็บข้อมูลและแสงอาจมนหรือหาย")</td><td>@T("Identify critical features early so equipment, close-range capture, or complementary inspection can be evaluated.", "ระบุจุดสำคัญล่วงหน้าเพื่อเลือกอุปกรณ์ ระยะใกล้ หรือการตรวจเสริม")</td></tr>
    </tbody></table></div><div class="service-note">@T("Achievable detail and measurement uncertainty depend on object size, surface, access, environment, scanner setup, alignment strategy, and requested output. A single accuracy number cannot describe every project.", "รายละเอียดและความไม่แน่นอนขึ้นกับขนาด ผิว การเข้าถึง สภาพแวดล้อม การตั้งเครื่อง วิธีจัดแนว และผลลัพธ์ที่ต้องการ จึงไม่ควรใช้ตัวเลขความแม่นยำเดียวกับทุกโครงการ")</div></div></section>

    <section id="scanning-guides" class="service-section service-section-soft"><div class="service-container"><header class="service-heading center"><p class="service-eyebrow">@T("MALIEV 3D Scanning Guides", "คู่มืองานสแกน 3D จาก MALIEV")</p><h2>@T("Prepare the part and choose the right deliverable", "เตรียมชิ้นงานและเลือกไฟล์ส่งมอบให้เหมาะสม")</h2><p>@T("Use these guides to plan access, surface preparation, reverse engineering, and replacement-part reconstruction.", "ใช้คู่มือเหล่านี้วางแผนการเข้าถึง การเตรียมผิว Reverse Engineering และการสร้างอะไหล่ทดแทน")</p></header><div class="service-card-grid">
        <article class="service-card"><h3>@T("Prepare a part for scanning", "เตรียมชิ้นงานก่อนสแกน 3D")</h3><p>@T("Check access, surface condition, reflective or transparent regions, reference targets, and the required output before the visit.", "ตรวจสอบการเข้าถึง สภาพผิว บริเวณเงาหรือใส จุดอ้างอิง และไฟล์ที่ต้องการก่อนนัดหมาย")</p><p><a href="https://shop.maliev.com/blogs/news/prepare-part-for-3d-scanning-service">@T("Read the scanning-preparation guide", "อ่านคู่มือเตรียมชิ้นงานสแกน")</a></p></article>
        <article class="service-card"><h3>@T("Understand scan-to-CAD work", "เข้าใจขั้นตอนจากข้อมูลสแกนสู่ CAD")</h3><p>@T("See why a triangular mesh is not automatically editable manufacturing CAD and when reconstruction is required.", "เข้าใจว่าเมชสามเหลี่ยมไม่ใช่ CAD สำหรับผลิตที่แก้ไขได้โดยอัตโนมัติ และเมื่อใดต้องสร้างแบบใหม่")</p><p><a href="https://shop.maliev.com/blogs/news/3d-scan-to-cad-reverse-engineering">@T("Read the scan-to-CAD guide", "อ่านคู่มือจากสแกนสู่ CAD")</a></p></article>
        <article class="service-card"><h3>@T("Recreate a part without CAD", "สร้างอะไหล่ทดแทนเมื่อไม่มีไฟล์ CAD")</h3><p>@T("Review what can be recovered from a physical sample, how wear affects design intent, and which manufacturing path may follow.", "ดูว่ากู้ข้อมูลใดจากชิ้นงานตัวอย่างได้ การสึกหรอมีผลต่อแบบเดิมอย่างไร และควรผลิตต่อด้วยวิธีใด")</p><p><a href="https://shop.maliev.com/blogs/news/recreate-replacement-part-without-cad">@T("Read the replacement-part guide", "อ่านคู่มือสร้างอะไหล่ทดแทน")</a></p></article>
    </div></div></section>

    <section id="scanning-faq" class="service-section"><div class="service-container"><header class="service-heading center"><p class="service-eyebrow">@T("3D Scanning FAQ", "คำถามงานสแกน 3D")</p><h2>@T("Plan the right scanning scope", "วางขอบเขตงานสแกนให้ถูกต้อง")</h2></header><div class="service-faq">
        <details><summary>@T("How much does 3D scanning cost?", "สแกน 3D ราคาเท่าไร?")</summary><p>@T("Raw 3D scanning with STL output starts at THB 2,500. Reverse-engineering output starts at THB 4,500. A deviation-analysis report adds THB 1,000. The final quotation depends on size, complexity, preparation, scan positions, site access, cleanup, alignment, and required deliverables.", "งานสแกน 3D พร้อมไฟล์ STL ดิบเริ่มต้น 2,500 บาท งาน Reverse Engineering เริ่มต้น 4,500 บาท และรายงาน Deviation Analysis เพิ่ม 1,000 บาท ราคาสุดท้ายขึ้นกับขนาด ความซับซ้อน การเตรียมผิว จำนวนตำแหน่งสแกน การเข้าพื้นที่ การเก็บข้อมูล การจัดแนว และผลส่งมอบ")</p></details>
        <details><summary>@T("How long does 3D scanning take?", "งานสแกน 3D ใช้เวลานานเท่าไร?")</summary><p>@T("Simple scanning work can be completed within the same day. Lead time increases with part complexity, surface preparation, the number of scan positions, mesh cleanup, reverse engineering, inspection, and reporting requirements.", "งานสแกนที่ไม่ซับซ้อนอาจเสร็จภายในวันเดียว ระยะเวลาจะเพิ่มตามความซับซ้อนของชิ้นงาน การเตรียมผิว จำนวนตำแหน่งสแกน การเก็บเมช งาน Reverse Engineering การตรวจสอบ และรูปแบบรายงาน")</p></details>
        <details><summary>@T("Which part should I bring for scanning, and can broken parts be repaired digitally?", "ควรนำชิ้นงานสภาพใดมาสแกน และซ่อมชิ้นงานที่แตกในโมเดลได้หรือไม่?")</summary><p>@T("Bring the example in the best available condition because the scan captures the geometry that is physically present. Broken parts can still be scanned, and missing or damaged areas can often be reconstructed or modified in the 3D model when sufficient reference geometry and design intent are available.", "ควรนำชิ้นงานที่มีสภาพดีที่สุดเท่าที่มี เพราะการสแกนจะเก็บรูปทรงที่มีอยู่จริง ชิ้นงานแตกยังสามารถสแกนได้ และมักสร้างหรือแก้ไขส่วนที่หายหรือเสียหายในโมเดล 3D ได้เมื่อมีรูปทรงอ้างอิงและข้อมูลเจตนาการออกแบบเพียงพอ")</p></details>
        <details><summary>@T("What sizes and subjects can you scan?", "สแกนวัตถุขนาดและประเภทใดได้บ้าง?")</summary><p>@T("Our optical scanners can capture subjects ranging from small gears to a 6-metre private aircraft when access and conditions are suitable. Sculptures, art pieces, and a stationary human can also be scanned. Scope, achievable detail, setup, and deliverables are assessed for each subject.", "เครื่องสแกนแบบออปติคัลของเรารองรับตั้งแต่เฟืองขนาดเล็กไปจนถึงเครื่องบินส่วนตัวขนาด 6 เมตรเมื่อพื้นที่และสภาพแวดล้อมเหมาะสม ประติมากรรม งานศิลปะ และบุคคลที่อยู่นิ่งก็สามารถสแกนได้ โดยจะประเมินขอบเขต รายละเอียดที่ทำได้ การตั้งเครื่อง และผลส่งมอบเป็นรายกรณี")</p></details>
        <details><summary>@T("Which scan files can you deliver?", "ส่งมอบไฟล์สแกนรูปแบบใดได้บ้าง?")</summary><p>@T("Raw geometry is commonly delivered as STL. We can also provide OBJ with captured colour when the project and capture method support colour data. Reverse-engineering projects can add editable CAD deliverables such as STEP or IGES as agreed.", "ข้อมูลรูปทรงดิบโดยทั่วไปส่งเป็น STL และสามารถส่ง OBJ พร้อมสีได้เมื่อโครงการและวิธีเก็บข้อมูลรองรับสี งาน Reverse Engineering สามารถเพิ่มไฟล์ CAD ที่แก้ไขได้ เช่น STEP หรือ IGES ตามขอบเขตที่ตกลง")</p></details>
        <details><summary>@T("What is the scanner's volumetric accuracy?", "ความแม่นยำเชิงปริมาตรของเครื่องสแกนเท่าไร?")</summary><p>@T("The scanner's volumetric accuracy specification is 0.02 mm + 0.06 mm/m. Actual project results also depend on object size and surface, preparation, access, environment, scanner setup, alignment strategy, and the requested deliverable.", "ข้อกำหนดความแม่นยำเชิงปริมาตรของเครื่องสแกนคือ 0.02 มม. + 0.06 มม./ม. ผลลัพธ์จริงของแต่ละโครงการยังขึ้นกับขนาดและผิวชิ้นงาน การเตรียม การเข้าถึง สภาพแวดล้อม การตั้งเครื่อง วิธีจัดแนว และผลส่งมอบที่ต้องการ")</p></details>
        <details><summary>@T("Can you scan outdoors, buildings, or factories?", "สแกนกลางแจ้ง อาคาร หรือโรงงานได้หรือไม่?")</summary><p>@T("We cannot perform optical 3D scanning outdoors under direct sunlight because sunlight overwhelms the projected light used by this scanning technology. We also do not offer whole-building or whole-factory scanning because we do not have a LiDAR 3D scanner. Onsite scanning of suitable parts and equipment remains available in controlled lighting.", "เราไม่สามารถสแกน 3D แบบออปติคัลกลางแจ้งภายใต้แสงแดดโดยตรงได้ เพราะแสงแดดรบกวนแสงที่เครื่องฉายซึ่งเป็นข้อจำกัดของเทคโนโลยีนี้ และไม่รับสแกนอาคารหรือโรงงานทั้งพื้นที่เนื่องจากเราไม่มีเครื่องสแกน 3D แบบ LiDAR แต่ยังให้บริการสแกนชิ้นส่วนและอุปกรณ์นอกสถานที่ได้เมื่อควบคุมแสงอย่างเหมาะสม")</p></details>
        <details><summary>@T("Can every object be scanned?", "ทุกวัตถุสแกนได้หรือไม่?")</summary><p>@T("No. The scanner needs line of sight and a stable optical response. Transparent, mirror-like, moving, very hot, inaccessible, internal, extremely small, or unsafe subjects may need preparation, partial results, another method, or may not be feasible.", "ไม่ได้ทุกวัตถุ เครื่องต้องมองเห็นผิวและรับแสงที่เสถียร วัตถุใส เงากระจก เคลื่อนที่ ร้อน เข้าถึงไม่ได้ อยู่ภายใน เล็กมาก หรือไม่ปลอดภัย อาจต้องเตรียม ได้ข้อมูลบางส่วน ใช้วิธีอื่น หรือทำไม่ได้")</p></details>
        <details><summary>@T("Is an STL file editable CAD?", "ไฟล์ STL เป็น CAD ที่แก้ไขได้หรือไม่?")</summary><p>@T("An STL is normally a triangular surface mesh. It can be measured and edited with mesh tools, but it does not contain the parametric features, sketches, dimensions, and design intent of a native CAD model. Reverse engineering adds that reconstruction work.", "STL เป็นผิวสามเหลี่ยม สามารถวัดและแก้ด้วยเครื่องมือเมช แต่ไม่มีฟีเจอร์พาราเมตริก สเก็ตช์ ขนาด และเจตนาการออกแบบแบบ CAD งาน Reverse Engineering คือการสร้างข้อมูลเหล่านี้ใหม่")</p></details>
        <details><summary>@T("Does reverse engineering recover the original CAD exactly?", "Reverse Engineering กู้ CAD ต้นฉบับได้เหมือนเดิมหรือไม่?")</summary><p>@T("No. It reconstructs an engineering model from visible, measurable geometry and agreed design assumptions. Wear, damage, inaccessible areas, deformation, casting variation, and unknown original intent require judgment and may not reproduce original feature history.", "ไม่ใช่ เป็นการสร้างโมเดลวิศวกรรมจากรูปทรงที่มองเห็นและวัดได้ร่วมกับสมมติฐานที่ตกลง การสึก ความเสียหาย จุดที่เข้าไม่ถึง การเสียรูป ความแปรปรวนงานหล่อ และเจตนาเดิมที่ไม่ทราบต้องใช้วิจารณญาณ")</p></details>
        <details><summary>@T("What is needed for deviation analysis?", "Deviation Analysis ต้องใช้อะไร?")</summary><p>@T("Usually the physical part, usable nominal CAD, a defined alignment method, critical regions, reporting needs, and an agreed interpretation of color limits. The result shows differences relative to that alignment; it is not automatically certified dimensional inspection.", "โดยทั่วไปต้องมีชิ้นงาน CAD ต้นแบบ วิธีจัดแนว จุดสำคัญ รูปแบบรายงาน และช่วงสีที่ตกลง ผลแสดงความต่างตามการจัดแนวนั้น ไม่ได้เป็นการตรวจมิติรับรองโดยอัตโนมัติ")</p></details>
        <details><summary>@T("Can you scan at our factory or site?", "ไปสแกนที่โรงงานหรือหน้างานได้หรือไม่?")</summary><p>@T("Yes. We provide onsite scanning when feasibility, access, safety, environment, working space, and schedule are agreed. Send photos, approximate dimensions, location, restrictions, and required deliverables for planning.", "ได้ เรามีบริการนอกสถานที่เมื่อประเมินความเป็นไปได้ การเข้าถึง ความปลอดภัย สภาพแวดล้อม พื้นที่ และตารางแล้ว กรุณาส่งรูป ขนาดโดยประมาณ สถานที่ ข้อจำกัด และผลลัพธ์ที่ต้องการ")</p></details>
    </div></div></section>

    <ServiceLocation />

    <section class="service-cta-wrap"><div class="service-container service-cta"><div><h2>@T("Tell us what you need after the scan", "บอกเราว่าต้องการนำข้อมูลสแกนไปทำอะไร")</h2><p>@T("Share photos, size, location, surface condition, critical areas, nominal CAD, and target files. We will help define an appropriate scope.", "ส่งรูป ขนาด สถานที่ สภาพผิว จุดสำคัญ CAD ต้นแบบ และไฟล์ที่ต้องการ เราจะช่วยกำหนดขอบเขตที่เหมาะสม")</p></div><div class="service-actions"><a class="service-button service-button-yellow" href="/Quotation?item=3D-Scanning">@T("Request a Quote", "ขอใบเสนอราคา") <i class="fas fa-arrow-right" aria-hidden="true"></i></a></div></div></section>
