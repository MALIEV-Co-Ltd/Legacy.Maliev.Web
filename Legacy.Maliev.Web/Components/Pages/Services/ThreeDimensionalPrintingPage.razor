@page "/services/3d-printing"
@using System.Globalization
@using System.Text.Json
@using Legacy.Maliev.Web.Components.Layout
@using Legacy.Maliev.Web.Components.Metadata
@inject IHttpContextAccessor HttpContextAccessor

@{
    var context = HttpContextAccessor.HttpContext
        ?? throw new InvalidOperationException("Static SSR requires an active HTTP context.");
    var title = T(
        "3D Printing Services Bangkok & Nonthaburi | Instant Online Quote",
        "รับพิมพ์ 3D และรับปริ้น 3D กรุงเทพและนนทบุรี | ประเมินราคาออนไลน์");
    var description = T(
        "Order FDM and resin 3D printed parts in engineering materials. Compare material uses, prepare files, and upload CAD for instant 3D printing pricing.",
        "MALIEV รับพิมพ์ 3D ด้วยระบบ FDM และเรซินสำหรับต้นแบบและชิ้นงานใช้งานจริง เลือกวัสดุ อัปโหลดไฟล์ และประเมินราคาออนไลน์");
    var keywords = T(
        "3D printing service Thailand, 3D print price, order 3D print Bangkok, FDM printing, resin printing",
        "รับปริ้น 3D, ปริ้น 3D ราคา, ร้านปริ้น 3D, สั่งพิมพ์ 3 มิติ, พิมพ์เรซิน");
    var faqJson = CreateFaqJson();
}
<PageTitle>@title</PageTitle>
<HeadContent>
    <meta name="description" content="@description" />
    <meta name="keywords" content="@keywords" />
    <link rel="preload" as="image" href="/src/images/services/printing/printing-hero.webp" />
    <PublicOpenGraphMetadata Model="@(PublicOpenGraphMetadataDisplayModel.Create(context, title, description, image: null))" />
    <PublicDocumentLinks Model="@(PublicDocumentLinksDisplayModel.Create(context))" />
    <PublicServiceStructuredData Model="@(PublicServiceStructuredDataDisplayModel.Create("3D Printing"))" />
    <script type="application/ld+json">@((MarkupString)faqJson)</script>
</HeadContent>
<ThreeDimensionalPrintingContent RouteOwner="blazor-static-ssr" />

@code {
    private bool IsThai => CultureInfo.CurrentCulture.TwoLetterISOLanguageName == "th";

    private string CreateFaqJson()
    {
        var schema = new Dictionary<string, object>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "FAQPage",
            ["mainEntity"] = new object[]
            {
                CreateQuestion(
                    T("How much does 3D printing cost?", "พิมพ์ 3D ราคาเท่าไร?"),
                    T(
                        "Cost depends on material, occupied volume, print time, support, orientation, risk, finishing, and quantity. Upload the model to MALIEV Instant Quotation for an estimate.",
                        "ราคาขึ้นกับวัสดุ ปริมาตร เวลา ซัพพอร์ต ทิศทาง ความเสี่ยง การเก็บงาน และจำนวน อัปโหลดโมเดลในหน้าประเมินราคา MALIEV เพื่อรับราคา")),
                CreateQuestion(
                    T("Can you print only one part?", "รับพิมพ์เพียง 1 ชิ้นหรือไม่?"),
                    T(
                        "Yes. MALIEV has no minimum quantity for 3D printing.",
                        "รับพิมพ์ตั้งแต่ 1 ชิ้น ไม่มีจำนวนขั้นต่ำ")),
                CreateQuestion(
                    T("Which 3D printing material is strongest?", "วัสดุพิมพ์ 3D ใดแข็งแรงที่สุด?"),
                    T(
                        "There is no single strongest material for every condition. Consider stiffness, impact, fatigue, heat, chemicals, moisture, UV, layer direction, and the required failure mode.",
                        "ไม่มีวัสดุเดียวที่แข็งแรงที่สุดทุกสภาพ ต้องพิจารณาความแข็ง แรงกระแทก ความล้า ความร้อน สารเคมี ความชื้น UV ทิศทางชั้น และลักษณะการเสียหาย"))
            }
        };

        return JsonSerializer.Serialize(schema);
    }

    private static Dictionary<string, object> CreateQuestion(string question, string answer) => new()
    {
        ["@type"] = "Question",
        ["name"] = question,
        ["acceptedAnswer"] = new Dictionary<string, object>
        {
            ["@type"] = "Answer",
            ["text"] = answer
        }
    };

    private string T(string english, string thai) => IsThai ? thai : english;
}
