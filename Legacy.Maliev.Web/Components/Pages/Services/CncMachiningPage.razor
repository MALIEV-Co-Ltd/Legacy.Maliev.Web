@page "/services/cnc-machining"
@using System.Globalization
@using System.Text.Json
@using Legacy.Maliev.Web.Components.Layout
@using Legacy.Maliev.Web.Components.Metadata
@inject IHttpContextAccessor HttpContextAccessor

@{
    var context = HttpContextAccessor.HttpContext
        ?? throw new InvalidOperationException("Static SSR requires an active HTTP context.");
    var title = T(
        "CNC Machining Services in Bangkok & Nonthaburi | One-Off and Production Parts",
        "รับงาน CNC ตามแบบ กรุงเทพและนนทบุรี | งานชิ้นเดียวถึงงานผลิต");
    var description = T(
        "CNC milling and turning for one-off parts, prototypes, jigs and production. Common JIS metals and engineering plastics. Send CAD and drawings for a quote.",
        "MALIEV รับผลิตชิ้นงาน CNC ตามไฟล์ CAD และแบบงาน ตั้งแต่งานชิ้นเดียว ต้นแบบ จิ๊ก ไปจนถึงงานผลิตซ้ำ รองรับโลหะและพลาสติกวิศวกรรม");
    var keywords = T(
        "CNC machining Thailand, CNC aluminum, CNC one piece, machine shop Bangkok, CNC Nonthaburi",
        "รับ CNC อลูมิเนียม, รับกลึง CNC, โรงกลึง นนทบุรี, CNC งานชิ้นเดียว, โรงงาน CNC");
    var faqJson = CreateFaqJson();
}
<PageTitle>@title</PageTitle>
<HeadContent>
    <meta name="description" content="@description" />
    <meta name="keywords" content="@keywords" />
    <link rel="preload" as="image" href="/src/images/services/cnc/cnc-hero.webp" />
    <PublicOpenGraphMetadata Model="@(PublicOpenGraphMetadataDisplayModel.Create(context, title, description, image: null))" />
    <PublicDocumentLinks Model="@(PublicDocumentLinksDisplayModel.Create(context))" />
    <PublicServiceStructuredData Model="@(PublicServiceStructuredDataDisplayModel.Create("CNC Machining"))" />
    <script type="application/ld+json">@((MarkupString)faqJson)</script>
</HeadContent>
<CncMachiningContent RouteOwner="blazor-static-ssr" />

@code {
    private static bool IsThai => CultureInfo.CurrentCulture.TwoLetterISOLanguageName == "th";

    public static string CreateFaqJson()
    {
        var schema = new Dictionary<string, object>
        {
            ["@context"] = "https://schema.org",
            ["@type"] = "FAQPage",
            ["mainEntity"] = new object[]
            {
                CreateQuestion(
                    T("Can you machine only one piece?", "รับทำ CNC เพียง 1 ชิ้นหรือไม่?"),
                    T(
                        "Yes. We accept one-off parts when the geometry, material, and project scope are feasible. Setup and programming are distributed across the quantity, so unit price usually improves with repeat quantities.",
                        "รับงานชิ้นเดียวเมื่อรูปทรง วัสดุ และขอบเขตงานผลิตได้จริง ค่าเตรียมเครื่องและเขียนโปรแกรมจะเฉลี่ยตามจำนวน ดังนั้นราคาต่อชิ้นมักลดลงเมื่อผลิตหลายชิ้น")),
                CreateQuestion(
                    T("How much does CNC machining cost?", "งาน CNC ราคาเท่าไร?"),
                    T(
                        "CNC machining starts at THB 2,500. The final price depends on material and stock, part size, machining time, number of setups, tooling, tolerances, finish, inspection, and quantity. Send CAD and a drawing for an accurate quotation.",
                        "งาน CNC เริ่มต้น 2,500 บาท ราคาสุดท้ายขึ้นกับวัสดุและสต็อก ขนาดชิ้นงาน เวลาเครื่อง จำนวนครั้งจับยึด เครื่องมือ ค่าคลาดเคลื่อน ผิว การตรวจสอบ และจำนวน ควรส่ง CAD และแบบงานเพื่อประเมินราคาอย่างแม่นยำ")),
                CreateQuestion(
                    T("What is the usual CNC machining lead time?", "งาน CNC ใช้เวลาผลิตเท่าไร?"),
                    T(
                        "Lead time usually starts at about 14 days. The schedule includes material sourcing, CAM preparation and programming, machine setup and loading, machining, and final inspection—not only the time when material is being cut.",
                        "ระยะเวลาผลิตโดยทั่วไปเริ่มต้นประมาณ 14 วัน เพราะรวมการจัดหาวัสดุ การเตรียม CAM และเขียนโปรแกรม การตั้งเครื่องและโหลดวัสดุ การผลิต และการตรวจสอบขั้นสุดท้าย ไม่ได้มีเฉพาะเวลาที่เครื่องกำลังตัดชิ้นงาน")),
                CreateQuestion(
                    T("Are rush CNC orders available?", "มีบริการเร่งด่วนสำหรับงาน CNC หรือไม่?"),
                    T(
                        "Rush orders may be possible when machine capacity, material availability, tooling, geometry, and inspection requirements allow. An additional markup applies because the job must be prioritized and the production plan adjusted. Ask us to confirm feasibility before relying on a rush date.",
                        "อาจรับงานเร่งด่วนได้เมื่อกำลังการผลิต วัสดุ เครื่องมือ รูปทรง และข้อกำหนดการตรวจสอบเอื้ออำนวย โดยมีค่าบริการเพิ่มเนื่องจากต้องจัดลำดับงานและปรับแผนการผลิต กรุณาให้เรายืนยันก่อนวางแผนตามกำหนดเร่งด่วน")),
                CreateQuestion(
                    T("What file formats should I send?", "ควรส่งไฟล์อะไร?"),
                    T(
                        "A STEP or other usable solid CAD file is preferred for geometry, together with a PDF drawing for critical manufacturing requirements. Contact us if only a sample or legacy drawing is available.",
                        "แนะนำไฟล์ STEP หรือไฟล์ solid CAD พร้อมแบบ PDF ระบุข้อกำหนดสำคัญ หากมีเพียงตัวอย่างหรือแบบเก่า โปรดปรึกษาเรา")),
                CreateQuestion(
                    T("Can you copy an existing part?", "สามารถลอกแบบชิ้นส่วนเดิมได้หรือไม่?"),
                    T(
                        "Often yes, but the correct route may include measurement or 3D scanning, reverse engineering, material identification, and a review of wear or damage. The original design intent cannot always be recovered from a worn sample.",
                        "หลายกรณีทำได้ แต่อาจต้องวัดหรือสแกน 3D ทำ Reverse Engineering ตรวจชนิดวัสดุ และประเมินการสึกหรอ ไม่สามารถกู้เจตนาการออกแบบเดิมทั้งหมดจากชิ้นงานที่สึกได้เสมอ")),
                CreateQuestion(
                    T("Do you guarantee the same tolerance for every feature?", "ทุกฟีเจอร์ใช้ค่าคลาดเคลื่อนเดียวกันหรือไม่?"),
                    T(
                        "No. Achievable tolerance depends on geometry, size, material, setup, process, and inspection method. Critical tolerances must be identified and agreed before production.",
                        "ไม่ใช่ ค่าที่ทำได้ขึ้นกับรูปทรง ขนาด วัสดุ การจับยึด กระบวนการ และวิธีตรวจ ต้องระบุและตกลงจุดสำคัญก่อนผลิต"))
            }
        };

        return JsonSerializer.Serialize(schema);
    }

    private static Dictionary<string, object> CreateQuestion(string question, string answer) => new()
    {
        ["@type"] = "Question",
        ["name"] = question,
        ["acceptedAnswer"] = new Dictionary<string, object>
        {
            ["@type"] = "Answer",
            ["text"] = answer
        }
    };

    private static string T(string english, string thai) => IsThai ? thai : english;
}
