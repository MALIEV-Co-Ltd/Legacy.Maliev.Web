@using System.Text.Json
@inject IStringLocalizer<GuidelinesContent> Localizer

<script type="application/ld+json" data-migration-component="knowledge-guidelines-structured-data" data-migration-renderer="blazor-static-ssr">@((MarkupString)StructuredDataJson)</script>

@code {
    [Parameter, EditorRequired]
    public required string CanonicalUrl { get; set; }

    private string StructuredDataJson => JsonSerializer.Serialize(new Dictionary<string, object>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "HowTo",
        ["name"] = Localizer["Quotation request guidelines"].Value,
        ["description"] = Localizer["Clear files and requirements let our engineers review feasibility, price, and lead time with fewer follow-up questions."].Value,
        ["url"] = CanonicalUrl,
        ["step"] = new[]
        {
            CreateStep(
                Localizer["Send usable files"].Value,
                Localizer["Provide a 3D CAD file when possible. Add a drawing when tolerances, threads, finishes, inspection points, or critical dimensions matter."].Value,
                "#guideline-files"),
            CreateStep(
                Localizer["Define the result"].Value,
                Localizer["State the process, material, quantity, color or finish, intended use, and required delivery date."].Value,
                "#guideline-result"),
            CreateStep(
                Localizer["Flag critical requirements"].Value,
                Localizer["Identify mating surfaces, cosmetic faces, dimensional priorities, assemblies, and any parts supplied by you."].Value,
                "#guideline-requirements"),
            CreateStep(
                Localizer["Protect confidential work"].Value,
                Localizer["Request our mutual NDA before sharing confidential project information when your organization requires it."].Value,
                "#guideline-confidentiality")
        }
    });

    private Dictionary<string, string> CreateStep(string name, string text, string fragment) => new()
    {
        ["@type"] = "HowToStep",
        ["name"] = name,
        ["text"] = text,
        ["url"] = $"{CanonicalUrl}{fragment}"
    };
}
