@inject IStringLocalizer<ContactContent> Localizer

<div data-migration-component="contact-details-content" data-migration-renderer="blazor-static-ssr">
    <h2 id="contact-details-title">@Localizer["Contact details"]</h2>
    <address>
        <strong>Maliev Co., Ltd.</strong><br />
        @Localizer["Nonthaburi, Thailand"]<br />
        <a href="mailto:info@maliev.com">info@maliev.com</a>
    </address>
    <iframe
        title="@Localizer["MALIEV office location"]"
        src="https://maps.google.com/maps?q=Maliev%20Co.%2C%20Ltd.%2C%20Nonthaburi%2C%20Thailand&amp;z=15&amp;output=embed"
        width="100%"
        height="360"
        style="border:0"
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"></iframe>
</div>
