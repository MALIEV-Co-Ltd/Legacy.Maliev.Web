@page "/Account/ResetPassword"
@using Microsoft.AspNetCore.Antiforgery
@inject IHttpContextAccessor HttpContextAccessor
@inject IAntiforgery Antiforgery
@inject IStringLocalizer<ResetPasswordContent> Localizer

@if (isValidChallenge)
{
    <PageTitle>@Localizer["Password Reset | MALIEV"]</PageTitle>
    <HeadContent><meta name="robots" content="noindex, nofollow" /></HeadContent>
    <main class="auth-page" data-migration-route-owner="blazor-static-ssr">
        <div class="maliev-container auth-shell">
            <section class="auth-intro"><p class="maliev-eyebrow">@Localizer["Account security"]</p><h1>@Localizer["Create a new password"]</h1></section>
            <section class="auth-card">
                <h1>@Localizer["Reset password"]</h1>
                <form method="post" class="maliev-form">
                    @if (tokens is not null)
                    {
                        <input type="hidden" name="@tokens.FormFieldName" value="@tokens.RequestToken" />
                    }
                    <ResetPasswordContent Model="model" />
                </form>
            </section>
        </div>
    </main>
}

@code {
    private ResetPasswordFormDisplayModel model = new(
        string.Empty,
        string.Empty,
        new Dictionary<string, IReadOnlyList<string>>());
    private AntiforgeryTokenSet? tokens;
    private bool isValidChallenge;

    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    protected override void OnParametersSet()
    {
        var context = HttpContextAccessor.HttpContext
            ?? throw new InvalidOperationException("Static SSR requires an active HTTP context.");
        context.Response.Headers.CacheControl = "no-store";
        context.Response.Headers["Referrer-Policy"] = "no-referrer";
        isValidChallenge = !string.IsNullOrWhiteSpace(Email) && !string.IsNullOrWhiteSpace(Token);
        if (!isValidChallenge)
        {
            context.Response.StatusCode = StatusCodes.Status400BadRequest;
            return;
        }

        model = new ResetPasswordFormDisplayModel(
            Email!,
            Token!,
            new Dictionary<string, IReadOnlyList<string>>());
        tokens = Antiforgery.GetAndStoreTokens(context);
    }
}
