@using Microsoft.AspNetCore.Components
@inject IStringLocalizer<LoginContent> Localizer

<div data-migration-component="login-content" data-migration-renderer="blazor-static-ssr">
    @if (!string.IsNullOrWhiteSpace(Model.Notification))
    {
        <div class="maliev-alert" role="status">@Model.Notification</div>
    }

    <div class="validation-summary-errors @(Model.AllErrors.Count > 0 ? string.Empty : "validation-summary-valid")" role="alert" data-valmsg-summary="true">
        <ul>
            @if (Model.AllErrors.Count == 0)
            {
                <li style="display:none"></li>
            }
            else
            {
                @foreach (var error in Model.AllErrors)
                {
                    <li>@error</li>
                }
            }
        </ul>
    </div>

    <input type="hidden" id="ReturnUrl" name="ReturnUrl" value="@Model.ReturnUrl" />
    <div class="maliev-form-field">
        <label for="Email">@Localizer["Email"]</label>
        <input autocomplete="email" autofocus type="email" data-val="true" data-val-email="The Email field is not a valid e-mail address." data-val-length="The field Email must be a string with a maximum length of 320." data-val-length-max="320" data-val-required="The Email field is required." id="Email" maxlength="320" name="Email" value="@Model.Email" />
        <span class="maliev-form-error @(HasError("Email") ? "field-validation-error" : "field-validation-valid")" data-valmsg-for="Email" data-valmsg-replace="true">@Model.FirstErrorFor("Email")</span>
    </div>
    <div class="maliev-form-field">
        <label for="Password">@Localizer["Password"]</label>
        <input autocomplete="current-password" type="password" data-val="true" data-val-length="The field Password must be a string with a maximum length of 1024." data-val-length-max="1024" data-val-required="The Password field is required." id="Password" maxlength="1024" name="Password" />
        <span class="maliev-form-error @(HasError("Password") ? "field-validation-error" : "field-validation-valid")" data-valmsg-for="Password" data-valmsg-replace="true">@Model.FirstErrorFor("Password")</span>
    </div>
    <label><input type="checkbox" data-val="true" data-val-required="The RememberMe field is required." id="RememberMe" name="RememberMe" value="true" checked="@Model.RememberMe" /> @Localizer["Remember me"]</label>
    <button type="submit" formaction="/Account/Login?handler=Login">@Localizer["Sign in"]</button>
    <input name="RememberMe" type="hidden" value="false" />
</div>

@code {
    [Parameter, EditorRequired]
    public LoginFormDisplayModel Model { get; set; } = null!;

    private bool HasError(string fieldName) => Model.ErrorsFor(fieldName).Count > 0;
}
