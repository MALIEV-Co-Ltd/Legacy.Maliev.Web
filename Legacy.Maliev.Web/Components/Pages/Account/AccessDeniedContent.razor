@inject IStringLocalizer<AccessDeniedContent> Localizer

<main class="maliev-page maliev-page-main" data-migration-component="access-denied-content" data-migration-renderer="blazor-static-ssr">
    <div class="maliev-container">
        <section class="maliev-panel maliev-status">
            <p class="maliev-eyebrow">@Localizer["Account access"]</p>
            <h1>@Localizer["Access denied"]</h1>
            <p>@Localizer["You are not authorized to see this content"]</p>
            <div class="maliev-actions">
                <a href="/" class="maliev-button">@Localizer["Back to the home page"]</a>
                <a href="/Contact" class="maliev-button maliev-button--secondary">@Localizer["Contact support"]</a>
            </div>
        </section>
    </div>
</main>
