@using Microsoft.AspNetCore.Components
@inject IStringLocalizer<ForgotPasswordContent> Localizer

<div data-migration-component="forgot-password-content" data-migration-renderer="blazor-static-ssr">
    @if (!string.IsNullOrWhiteSpace(Model.Notification))
    {
        <div class="maliev-alert" role="status">@Model.Notification</div>
    }

    <div class="validation-summary-errors @(Model.AllErrors.Count > 0 ? string.Empty : "validation-summary-valid")" role="alert" data-valmsg-summary="true">
        <ul>
            @if (Model.AllErrors.Count == 0)
            {
                <li style="display:none"></li>
            }
            else
            {
                @foreach (var error in Model.AllErrors)
                {
                    <li>@error</li>
                }
            }
        </ul>
    </div>

    <div class="maliev-form-field">
        <label for="Email">@Localizer["Email"]</label>
        <input autocomplete="email" type="email" data-val="true" data-val-email="The Email field is not a valid e-mail address." data-val-length="The field Email must be a string with a maximum length of 320." data-val-length-max="320" data-val-required="The Email field is required." id="Email" maxlength="320" name="Email" value="@Model.Email" />
        <span class="@(HasError("Email") ? "field-validation-error" : "field-validation-valid")" data-valmsg-for="Email" data-valmsg-replace="true">@Model.FirstErrorFor("Email")</span>
    </div>
    <button type="submit" formaction="/Account/ForgotPassword?handler=PasswordReset">@Localizer["Reset password"]</button>
</div>

@code {
    [Parameter, EditorRequired]
    public ForgotPasswordFormDisplayModel Model { get; set; } = null!;

    private bool HasError(string fieldName) => Model.ErrorsFor(fieldName).Count > 0;
}
