@using Microsoft.AspNetCore.Components
@inject IStringLocalizer<SignupContent> Localizer

<div data-migration-component="signup-content" data-migration-renderer="blazor-static-ssr">
    <div class="validation-summary-errors @(Model.AllErrors.Count > 0 ? string.Empty : "validation-summary-valid")" role="alert" data-valmsg-summary="true">
        <ul>
            @if (Model.AllErrors.Count == 0)
            {
                <li style="display:none"></li>
            }
            else
            {
                @foreach (var error in Model.AllErrors)
                {
                    <li>@error</li>
                }
            }
        </ul>
    </div>

    <div class="maliev-form-grid">
        <div class="maliev-form-field">
            <label for="FirstName">@Localizer["First name"]</label>
            <input autocomplete="given-name" type="text" data-val="true" data-val-length="The field FirstName must be a string with a maximum length of 100." data-val-length-max="100" data-val-required="The FirstName field is required." id="FirstName" maxlength="100" name="FirstName" value="@Model.FirstName" />
            <span class="@(HasError("FirstName") ? "field-validation-error" : "field-validation-valid")" data-valmsg-for="FirstName" data-valmsg-replace="true">@Model.FirstErrorFor("FirstName")</span>
        </div>
        <div class="maliev-form-field">
            <label for="LastName">@Localizer["Last name"]</label>
            <input autocomplete="family-name" type="text" data-val="true" data-val-length="The field LastName must be a string with a maximum length of 100." data-val-length-max="100" data-val-required="The LastName field is required." id="LastName" maxlength="100" name="LastName" value="@Model.LastName" />
            <span class="@(HasError("LastName") ? "field-validation-error" : "field-validation-valid")" data-valmsg-for="LastName" data-valmsg-replace="true">@Model.FirstErrorFor("LastName")</span>
        </div>
        <div class="maliev-form-field maliev-form-field--full">
            <label for="Email">@Localizer["Email"]</label>
            <input autocomplete="email" type="email" data-val="true" data-val-email="The Email field is not a valid e-mail address." data-val-length="The field Email must be a string with a maximum length of 320." data-val-length-max="320" data-val-required="The Email field is required." id="Email" maxlength="320" name="Email" value="@Model.Email" />
            <span class="@(HasError("Email") ? "field-validation-error" : "field-validation-valid")" data-valmsg-for="Email" data-valmsg-replace="true">@Model.FirstErrorFor("Email")</span>
        </div>
        <div class="maliev-form-field">
            <label for="Password">@Localizer["Password"]</label>
            <input autocomplete="new-password" type="password" data-val="true" data-val-length="The field Password must be a string with a minimum length of 6 and a maximum length of 1024." data-val-length-max="1024" data-val-length-min="6" data-val-required="The Password field is required." id="Password" maxlength="1024" name="Password" />
            <span class="@(HasError("Password") ? "field-validation-error" : "field-validation-valid")" data-valmsg-for="Password" data-valmsg-replace="true">@Model.FirstErrorFor("Password")</span>
        </div>
        <div class="maliev-form-field">
            <label for="ConfirmPassword">@Localizer["Retype Password"]</label>
            <input autocomplete="new-password" type="password" data-val="true" data-val-equalto="Passwords do not match." data-val-equalto-other="*.Password" data-val-required="The ConfirmPassword field is required." id="ConfirmPassword" name="ConfirmPassword" />
            <span class="@(HasError("ConfirmPassword") ? "field-validation-error" : "field-validation-valid")" data-valmsg-for="ConfirmPassword" data-valmsg-replace="true">@Model.FirstErrorFor("ConfirmPassword")</span>
        </div>
    </div>

    <input type="hidden" name="g-recaptcha-response" id="signup-recaptcha-response" value="" />
    <p>@Localizer["By signing up, you agree to our"] <a href="/Legal/TermsConditions">@Localizer["Terms and Conditions"]</a> @Localizer["and"] <a href="/Legal/PrivacyPolicy">@Localizer["Privacy Policy"]</a>.</p>
    <button type="submit" formaction="/Account/Signup?handler=SignUp" id="submit-button">@Localizer["Sign Up"]</button>
</div>

@code {
    [Parameter, EditorRequired]
    public SignupFormDisplayModel Model { get; set; } = null!;

    private bool HasError(string fieldName) => Model.ErrorsFor(fieldName).Count > 0;
}
