@page "/Account/ForgotPassword"
@using Microsoft.AspNetCore.Antiforgery
@using Microsoft.AspNetCore.Mvc.ViewFeatures
@inject IHttpContextAccessor HttpContextAccessor
@inject IAntiforgery Antiforgery
@inject ITempDataDictionaryFactory TempDataDictionaryFactory
@inject IStringLocalizer<ForgotPasswordContent> Localizer

<PageTitle>@Localizer["Forgot Password | MALIEV"]</PageTitle>
<HeadContent>
    <meta name="robots" content="noindex, nofollow" />
</HeadContent>
<main class="auth-page" data-migration-route-owner="blazor-static-ssr">
    <div class="maliev-container auth-shell">
        <section class="auth-intro">
            <p class="maliev-eyebrow">@Localizer["Account recovery"]</p>
            <h1>@Localizer["Return to your workspace"]</h1>
            <p>@Localizer["Enter your email address and we will send a secure reset link if the account is eligible."]</p>
        </section>
        <section class="auth-card">
            <h1>@Localizer["Forgot password"]</h1>
            <form method="post" class="maliev-form">
                @if (tokens is not null)
                {
                    <input type="hidden" name="@tokens.FormFieldName" value="@tokens.RequestToken" />
                }
                <ForgotPasswordContent Model="model" />
            </form>
            <footer class="auth-card__footer"><a href="/Account/Login">@Localizer["Back to sign in"]</a></footer>
        </section>
    </div>
</main>

@code {
    private ForgotPasswordFormDisplayModel model = new(
        string.Empty,
        null,
        new Dictionary<string, IReadOnlyList<string>>());
    private AntiforgeryTokenSet? tokens;

    protected override void OnInitialized()
    {
        var context = HttpContextAccessor.HttpContext
            ?? throw new InvalidOperationException("Static SSR requires an active HTTP context.");
        var tempData = TempDataDictionaryFactory.GetTempData(context);
        var notification = tempData.TryGetValue("Notification", out var value) ? value?.ToString() : null;
        model = new ForgotPasswordFormDisplayModel(
            string.Empty,
            notification,
            new Dictionary<string, IReadOnlyList<string>>());
        tokens = Antiforgery.GetAndStoreTokens(context);
    }
}
