@using System.Globalization
@inject IStringLocalizer<PublicFooter> Localizer

<footer class="landing-footer" data-migration-component="public-footer" data-migration-renderer="blazor-static-ssr">
    <div class="landing-footer-grid">
        <div class="landing-footer-brand">
            <img src="/src/images/navbar_logo_black.png" width="120" height="34" alt="MALIEV" />
            <p>@Localizer["Your trusted partner for CNC machining, 3D printing, and 3D scanning services."]</p>
            <div class="landing-social"><SocialLinks /></div>
        </div>
        <nav aria-label="@Localizer["Services"]">
            <h2>@Localizer["Services"]</h2>
            <ul>
                <li><a href="/Services/CNC-Machining">@Localizer["CNC Machining"]</a></li>
                <li><a href="/Services/3D-Printing">@Localizer["3D Printing"]</a></li>
                <li><a href="/Services/3D-Scanning">@Localizer["3D Scanning"]</a></li>
                <li><a href="/InstantQuotation/3D-Printing">@Localizer["Instant 3D Quotation"]</a></li>
                <li><a href="/Quotation">@Localizer["Get a Quote"]</a></li>
                <li><a href="https://shop.maliev.com/th" target="_blank" rel="noopener">@Localizer["Online Shop"]</a></li>
            </ul>
        </nav>
        <nav aria-label="@Localizer["Company"]">
            <h2>@Localizer["Company"]</h2>
            <ul>
                <li><a href="/About">@Localizer["About Us"]</a></li>
                <li><a href="/Career">@Localizer["Job Opportunities"]</a></li>
                <li><a href="/Contact">@Localizer["Contact Us"]</a></li>
                <li><a href="/Legal/TermsConditions">@Localizer["Terms and Conditions"]</a></li>
                <li><a href="/Legal/PrivacyPolicy">@Localizer["Privacy Policy"]</a></li>
                <li><a href="/Legal/NonDisclosureAgreement">@Localizer["Non-Disclosure Agreement"]</a></li>
            </ul>
        </nav>
        <div class="landing-footer-contact">
            <h2>@Localizer["Contact Us"]</h2>
            <a class="landing-footer-contact-row" href="mailto:info@maliev.com"><i class="far fa-envelope" aria-hidden="true"></i><span>info@maliev.com</span></a>
            <a class="landing-footer-contact-row" href="tel:+66818030404"><i class="fas fa-phone-alt" aria-hidden="true"></i><span>+66(0)81-803-0404</span></a>
            <a class="landing-footer-contact-row" href="tel:+66898950690"><i class="fas fa-phone-alt" aria-hidden="true"></i><span>+66(0)89-895-0690</span></a>
            <address class="landing-footer-contact-row">
                <i class="fas fa-map-marker-alt" aria-hidden="true"></i>
                <span class="landing-footer-address-text">
                    @Localizer["Maliev Co., Ltd."]<br />
                    @Localizer["36/1 Moo 3"]<br />
                    @if (IsThai)
                    {
                        @Localizer["Khlong Khoi, Pak Kret"]
                    }
                    else
                    {
                        <text>Khlong Khoi, <span class="maliev-nowrap">Pak Kret</span></text>
                    }
                    <br />@Localizer["Nonthaburi 11120"], @Localizer["Thailand"]
                </span>
            </address>
            <p class="landing-footer-contact-row"><i class="far fa-clock" aria-hidden="true"></i><span><strong>@Localizer["Business hours"]</strong><br />@Localizer["Monday-Friday: 09:00-18:00"]<br />@Localizer["Saturday-Sunday: Closed"]</span></p>
            @if (IsThai)
            {
                <p>เลขประจำตัวผู้เสียภาษี 0125561001573 (สำนักงานใหญ่)</p>
            }
        </div>
    </div>
    <div class="landing-footer-bottom">
        <span>&copy; @DateTime.UtcNow.Year Maliev Co., Ltd. @Localizer["All rights reserved."]</span>
        <span>@Localizer["Secure"] <b aria-hidden="true">•</b> @Localizer["Confidential"]</span>
    </div>
</footer>

@code {
    private static bool IsThai => CultureInfo.CurrentCulture.TwoLetterISOLanguageName == "th";
}
