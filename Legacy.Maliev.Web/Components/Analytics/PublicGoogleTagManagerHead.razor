<!-- Google Consent Mode and application-owned data layer -->
<script data-migration-component="public-google-tag-manager-head" data-migration-renderer="blazor-static-ssr">
    window.dataLayer = window.dataLayer || [];
    window.gtag = window.gtag || function () { window.dataLayer.push(arguments); };
    var consentState = '@Model.ConsentState';
    window.gtag('consent', 'default', {
        'ad_storage': consentState,
        'analytics_storage': consentState,
        'ad_user_data': consentState,
        'ad_personalization': consentState,
        'wait_for_update': 500
    });
    window.malievAnalytics = window.malievAnalytics || (function (initialConsentGranted) {
        var consentGranted = initialConsentGranted;
        var pendingEvents = [];

        function push(eventData) {
            if (!eventData || typeof eventData.event !== 'string') {
                return;
            }

            window.dataLayer.push(eventData);
        }

        return {
            emit: function (eventData) {
                if (consentGranted) {
                    push(eventData);
                    return;
                }

                pendingEvents.push(eventData);
            },
            setConsent: function (state) {
                consentGranted = state === 'granted';
                if (!consentGranted) {
                    pendingEvents.length = 0;
                    return;
                }

                pendingEvents.splice(0).forEach(push);
            }
        };
    })(consentState === 'granted');
    @((MarkupString)Model.QueuedEventScript)
</script>

<!-- Google Tag Manager: network loading is deferred until optional tracking is allowed. -->
<script>
    window.malievLoadGoogleTagManager = window.malievLoadGoogleTagManager || function () {
        if (document.querySelector('script[data-maliev-gtm-loader]')) {
            return;
        }

        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
            'gtm.start': new Date().getTime(),
            event: 'gtm.js'
        });

        var firstScript = document.getElementsByTagName('script')[0];
        var loader = document.createElement('script');
        loader.async = true;
        loader.setAttribute('data-maliev-gtm-loader', '');
        loader.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-KHDDLVRR';
        firstScript.parentNode.insertBefore(loader, firstScript);
    };

    if (consentState === 'granted') {
        window.malievLoadGoogleTagManager();
    }
</script>
<!-- End Google Tag Manager -->

@code {
    [Parameter, EditorRequired]
    public required PublicGoogleTagManagerDisplayModel Model { get; set; }
}
