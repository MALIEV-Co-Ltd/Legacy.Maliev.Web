@page "/Contact"
@model Legacy.Maliev.Web.Pages.Contact.Index
@using Legacy.Maliev.Web.Components.Pages.Contact
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ContactContent> ContactLocalizer
@{
    ViewData["Title"] = ContactLocalizer["Contact MALIEV"];
    ViewData["Description"] = ContactLocalizer["Contact MALIEV for CNC machining, additive manufacturing, 3D scanning, and custom manufacturing support."];
    ViewData["Keywords"] = ContactLocalizer["contact MALIEV, manufacturing enquiry, CNC quotation, 3D printing support"];
}

<component type="typeof(ContactHeroContent)" render-mode="Static" />

<main class="container maliev-section">
    <div class="row g-5">
        <section class="col-lg-7" aria-labelledby="contact-form-title">
            <h2 id="contact-form-title">@ContactLocalizer["Send an enquiry"]</h2>

            @if (!string.IsNullOrWhiteSpace(Model.Notification))
            {
                <div class="alert alert-success" role="status">@Model.Notification</div>
            }

            <form method="post" asp-page-handler="SubmitRequest" id="contact-form">
                <component type="typeof(ContactFormFields)" render-mode="Static" param-Model="Model.DisplayModel" />
            </form>
        </section>

        <aside class="col-lg-5" aria-labelledby="contact-details-title">
            <component type="typeof(ContactDetailsContent)" render-mode="Static" />
        </aside>
    </div>
</main>

@section Scripts {
    @if (!string.IsNullOrWhiteSpace(Model.RecaptchaSiteKey))
    {
        <script src="https://www.google.com/recaptcha/enterprise.js?render=@Uri.EscapeDataString(Model.RecaptchaSiteKey)" async defer></script>
        <script>
            (() => {
                const form = document.getElementById('contact-form');
                const tokenInput = document.getElementById('g-recaptcha-response');
                if (!form || !tokenInput) return;

                form.addEventListener('submit', event => {
                    if (tokenInput.value) return;
                    event.preventDefault();
                    grecaptcha.enterprise.ready(async () => {
                        tokenInput.value = await grecaptcha.enterprise.execute('@Model.RecaptchaSiteKey', { action: 'submit' });
                        form.requestSubmit();
                    });
                });
            })();
        </script>
    }
}
