@page "/Quotation"
@model Legacy.Maliev.Web.Pages.Quotation.Index
@using Legacy.Maliev.Web.Components.Pages.Quotation
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<QuotationContent> QuotationLocalizer
@{
    ViewData["Title"] = QuotationLocalizer["Request a manufacturing quotation"];
    ViewData["Description"] = QuotationLocalizer["Request a CNC machining, 3D printing, 3D scanning, or custom manufacturing quotation from MALIEV."];
    ViewData["Keywords"] = QuotationLocalizer["manufacturing quotation, CNC quote, 3D printing quote, 3D scanning quote"];
}

<component type="typeof(QuotationHeroContent)" render-mode="Static" />

<main class="container maliev-section">
    <section aria-labelledby="quotation-form-title">
        <div class="row justify-content-center">
            <div class="col-xl-9">
                <h2 id="quotation-form-title">@QuotationLocalizer["Manual quotation request"]</h2>

                @if (!string.IsNullOrWhiteSpace(Model.Notification))
                {
                    <div class="alert alert-info" role="status">@Model.Notification</div>
                }

                <form method="post" enctype="multipart/form-data" asp-page-handler="SubmitRequest" id="quotation-form">
                    <component type="typeof(QuotationFormFields)" render-mode="Static" param-Model="Model.DisplayModel" />
                </form>
            </div>
        </div>
    </section>
</main>

@section Scripts {
    @if (!string.IsNullOrWhiteSpace(Model.RecaptchaSiteKey))
    {
        <script src="https://www.google.com/recaptcha/enterprise.js?render=@Uri.EscapeDataString(Model.RecaptchaSiteKey)" async defer></script>
        <script>
            (() => {
                const form = document.getElementById('quotation-form');
                const tokenInput = document.getElementById('quotation-recaptcha-response');
                const filesInput = document.getElementById('Files');
                const serviceInput = document.getElementById('ServiceContext');
                let uploadStartEmitted = false;
                if (!form || !tokenInput) return;

                function emitUploadStart() {
                    if (uploadStartEmitted || !filesInput || filesInput.files.length === 0) return false;
                    if (!window.malievAnalytics || typeof window.malievAnalytics.emit !== 'function') return false;

                    uploadStartEmitted = true;
                    window.malievAnalytics.emit({
                        event: 'file_upload_start',
                        service: serviceInput ? serviceInput.value : 'custom_manufacturing',
                        file_count: filesInput.files.length
                    });
                    return true;
                }

                form.addEventListener('submit', event => {
                    if (tokenInput.value) {
                        if (!emitUploadStart()) return;

                        event.preventDefault();
                        window.setTimeout(function () {
                            form.submit();
                        }, 150);
                        return;
                    }
                    event.preventDefault();
                    grecaptcha.enterprise.ready(async () => {
                        tokenInput.value = await grecaptcha.enterprise.execute('@Model.RecaptchaSiteKey', { action: 'submit' });
                        form.requestSubmit();
                    });
                });
            })();
        </script>
    }
}
