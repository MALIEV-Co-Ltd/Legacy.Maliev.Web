@if (User.Identity?.IsAuthenticated == true)
{
    <li class="nav-item">
        <a class="nav-link maliev-account-link" asp-area="Member" asp-page="/Index">
            <i class="far fa-user" aria-hidden="true"></i>
            <span>@(User.Identity.Name ?? Localizer["Account"].Value)</span>
        </a>
    </li>
    <li class="nav-item">
        <form method="post" asp-area="" asp-page="/Account/Logout">
            <button type="submit" class="nav-link btn btn-link maliev-account-link">
                <i class="fas fa-sign-out-alt" aria-hidden="true"></i>
                <span>@Localizer["Logout"]</span>
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link maliev-account-link" asp-area="" asp-page="/Account/Login">
            <i class="far fa-user" aria-hidden="true"></i>
            <span>@Localizer["Login"]</span>
        </a>
    </li>
}
