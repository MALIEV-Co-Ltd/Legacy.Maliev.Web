@{
    bool isThai = System.Threading.Thread.CurrentThread.CurrentCulture.TwoLetterISOLanguageName == "th";
    Func<string, string, string> T = (en, th) => isThai ? th : en;
}

<section class="service-section service-section-soft" aria-labelledby="service-location-title">
    <div class="service-container service-split">
        <div class="service-copy">
            <p class="service-eyebrow">@T("Verified workshop and contact", "สถานที่และช่องทางติดต่อที่ยืนยันแล้ว")</p>
            <h2 id="service-location-title">
                @if (isThai)
                {
                    <text>บริการผลิตชิ้นงานจาก<span class="maliev-nowrap">ปากเกร็ด</span> นนทบุรี</text>
                }
                else
                {
                    <text>Manufacturing support from <span class="maliev-nowrap">Pak Kret</span>, Nonthaburi</text>
                }
            </h2>
            <p>@T(
                "MALIEV supports customers in Bangkok and Nonthaburi and reviews projects across Thailand. Files and project details can be sent online; delivery and onsite work depends on service and project review.",
                "MALIEV ให้บริการลูกค้าในกรุงเทพและนนทบุรี พร้อมประเมินโครงการจากทั่วประเทศไทย สามารถส่งไฟล์และรายละเอียดออนไลน์ โดยการจัดส่งและงานนอกสถานที่ขึ้นกับประเภทบริการและการประเมินโครงการ")</p>
            <address>
                <strong>Maliev Co., Ltd.</strong><br />
                @if (isThai)
                {
                    <text>36/1 หมู่ 3 ตำบลคลองข่อย อำเภอ<span class="maliev-nowrap">ปากเกร็ด</span> จังหวัดนนทบุรี 11120 ประเทศไทย</text>
                }
                else
                {
                    <text>36/1 Moo 3, Khlong Khoi, <span class="maliev-nowrap">Pak Kret</span>, Nonthaburi 11120, Thailand</text>
                }
            </address>
            <p>
                <strong>@T("Business hours", "เวลาทำการ")</strong><br />
                @T("Monday-Friday: 09:00-18:00", "จันทร์-ศุกร์: 09:00-18:00 น.")<br />
                @T("Saturday-Sunday: Closed", "เสาร์-อาทิตย์: ปิด")
            </p>
            <div class="service-actions">
                <a class="service-button service-button-primary" href="@Legacy.Maliev.Web.Application.SocialNetworks.GoogleMaps" target="_blank" rel="noopener">@T("Open Google Maps", "เปิด Google Maps")</a>
                <a class="service-button service-button-secondary" href="@Legacy.Maliev.Web.Application.SocialNetworks.Line" target="_blank" rel="noopener">@T("Chat on LINE OA", "ติดต่อผ่าน LINE OA")</a>
                <a class="service-button service-button-secondary" asp-page="/Quotation/Index">@T("Send files for review", "ส่งไฟล์เพื่อประเมิน")</a>
            </div>
        </div>
    </div>
</section>
