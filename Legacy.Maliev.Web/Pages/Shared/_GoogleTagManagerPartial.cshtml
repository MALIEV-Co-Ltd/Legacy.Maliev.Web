@using System.Text.Json
@using Legacy.Maliev.Web.Pages.Shared
@using Microsoft.AspNetCore.Http.Features
@using Microsoft.AspNetCore.Mvc.ViewFeatures
@inject ITempDataDictionaryFactory TempDataDictionaryFactory

@{
    var consentFeature = Context.Features.Get<ITrackingConsentFeature>();
    var consentState = consentFeature?.CanTrack == true ? "granted" : "denied";
    var tempData = TempDataDictionaryFactory.GetTempData(Context);
    var hasLeadEvent = LeadAnalyticsEventQueue.TryConsume(tempData, out var leadEvent);
    var leadEventJson = hasLeadEvent ? JsonSerializer.Serialize(leadEvent) : null;
}

<!-- Google Consent Mode and application-owned data layer -->
<script>
    window.dataLayer = window.dataLayer || [];
    window.gtag = window.gtag || function () { window.dataLayer.push(arguments); };
    var consentState = '@consentState';
    window.gtag('consent', 'default', {
        'ad_storage': consentState,
        'analytics_storage': consentState,
        'ad_user_data': consentState,
        'ad_personalization': consentState,
        'wait_for_update': 500
    });
    window.malievAnalytics = window.malievAnalytics || (function (initialConsentGranted) {
        var consentGranted = initialConsentGranted;
        var pendingEvents = [];

        function push(eventData) {
            if (!eventData || typeof eventData.event !== 'string') {
                return;
            }

            window.dataLayer.push(eventData);
        }

        return {
            emit: function (eventData) {
                if (consentGranted) {
                    push(eventData);
                    return;
                }

                pendingEvents.push(eventData);
            },
            setConsent: function (state) {
                consentGranted = state === 'granted';
                if (!consentGranted) {
                    pendingEvents.length = 0;
                    return;
                }

                pendingEvents.splice(0).forEach(push);
            }
        };
    })(consentState === 'granted');
    @if (hasLeadEvent)
    {
        <text>window.malievAnalytics.emit(@Html.Raw(leadEventJson));</text>
        if (leadEvent?.FileUploadCompleted == true)
        {
            var fileUploadEventJson = JsonSerializer.Serialize(new
            {
                @event = "file_upload_complete",
                service = leadEvent.Service,
                transaction_id = leadEvent.TransactionId,
            });
            <text>window.malievAnalytics.emit(@Html.Raw(fileUploadEventJson));</text>
        }
    }
</script>

<!-- Google Tag Manager -->
<script>
    (function (w, d, s, l, i) {
    w[l] = w[l] || []; w[l].push({
        'gtm.start':
            new Date().getTime(), event: 'gtm.js'
    }); var f = d.getElementsByTagName(s)[0],
        j = d.createElement(s), dl = l != 'dataLayer' ? '&l=' + l : ''; j.async = true; j.src =
            'https://www.googletagmanager.com/gtm.js?id=' + i + dl; f.parentNode.insertBefore(j, f);
    })(window, document, 'script', 'dataLayer', 'GTM-KHDDLVRR');</script>
