@using System.Globalization;

@inject IOptions<RequestLocalizationOptions> localizationOptions
@{

    var requestCulture = Context.Features.Get<IRequestCultureFeature>();
    var currentCulture = requestCulture?.RequestCulture.UICulture.Name ?? "th";
    var supportedCultures = localizationOptions.Value.SupportedUICultures ?? Array.Empty<CultureInfo>();
    var cultureItemsCompact = supportedCultures.Select(c => new SelectListItem { Value = c.Name, Text = c.TwoLetterISOLanguageName == "th" ? "ไทย" : "EN", Selected = c.Name == currentCulture }).ToList();
    var returnUrl = string.IsNullOrEmpty(Context.Request.Path) ? "~/" : $"~{Context.Request.Path.Value}";
}

<form class="maliev-language-form" method="post" role="form" asp-page="/Index" asp-page-handler="SetLanguage" asp-route-returnUrl="@returnUrl">
    <i class="fas fa-globe" aria-hidden="true"></i>
    <label class="visually-hidden" for="maliev-navbar-language">Select language</label>
    <select id="maliev-navbar-language" class="form-select form-select-sm maliev-language-select" name="culture" asp-items="cultureItemsCompact" onchange="this.form.submit()"></select>
</form>

<style>
    .maliev-language-form { display: flex; flex: 0 0 auto; align-items: center; gap: 0.45rem; inline-size: fit-content; min-inline-size: 0; margin: 0; color: #6f777e; }
    .maliev-language-select { flex: 0 0 4.75rem; inline-size: 4.75rem; min-inline-size: 4.75rem; color: #313b47; cursor: pointer; }
</style>
