@using Microsoft.AspNetCore.Http.Features

@{
    const string trackingConsentCookieName = "maliev_tracking_consent";
    var consentFeature = Context.Features.Get<ITrackingConsentFeature>();
    var hasRecordedDenial = string.Equals(Context.Request.Cookies[trackingConsentCookieName], "denied", StringComparison.Ordinal);
    var showBanner = consentFeature?.CanTrack != true && !hasRecordedDenial;
    var cookieString = consentFeature?.CreateConsentCookie();
}

@if (showBanner)
{
    <aside id="cookieConsent" class="privacy-consent" role="region" aria-labelledby="privacy-consent-title" aria-describedby="privacy-consent-description">
        <div class="privacy-consent__inner">
            <div class="privacy-consent__icon" aria-hidden="true">
                <i class="fas fa-shield-alt"></i>
            </div>
            <div class="privacy-consent__content">
                <strong id="privacy-consent-title">@Localizer["Your privacy choices"]</strong>
                <p id="privacy-consent-description">
                    @Localizer["This website uses cookies to ensure you get the best experience on our website."]
                    <a asp-page="/Legal/PrivacyPolicy">@Localizer["Learn more about our privacy policy"]</a>
                </p>
            </div>
            <div class="privacy-consent__actions" role="group" aria-label="@Localizer["Cookie choices"]">
                <button type="button" class="privacy-consent__reject" data-consent-action="reject">@Localizer["Reject optional cookies"]</button>
                <button type="button" class="accept-policy privacy-consent__accept" data-consent-action="accept" data-cookie-string="@cookieString">@Localizer["Accept cookies"]</button>
            </div>
        </div>
    </aside>
    <script>
        (function () {
            var cookieConsent = document.querySelector('#cookieConsent');
            var button = cookieConsent && cookieConsent.querySelector('[data-consent-action="accept"]');
            var rejectButton = cookieConsent && cookieConsent.querySelector('[data-consent-action="reject"]');
            if (!cookieConsent || !button || !rejectButton) {
                return;
            }

            function updateGoogleConsent(state) {
                window.dataLayer = window.dataLayer || [];
                window.gtag = window.gtag || function () { window.dataLayer.push(arguments); };
                window.gtag('consent', 'update', {
                    ad_storage: state,
                    analytics_storage: state,
                    ad_user_data: state,
                    ad_personalization: state
                });
                if (window.malievAnalytics && typeof window.malievAnalytics.setConsent === 'function') {
                    window.malievAnalytics.setConsent(state);
                }
            }

            button.addEventListener('click', function () {
                if (button.dataset.cookieString) {
                    document.cookie = button.dataset.cookieString;
                }

                document.cookie = 'maliev_tracking_consent=; Path=/; Max-Age=0; SameSite=Lax; Secure';
                updateGoogleConsent('granted');
                cookieConsent.remove();
            }, false);

            rejectButton.addEventListener('click', function () {
                document.cookie = 'maliev_tracking_consent=denied; Path=/; Max-Age=31536000; SameSite=Lax; Secure';
                updateGoogleConsent('denied');
                cookieConsent.remove();
            }, false);
        })();
    </script>
}
