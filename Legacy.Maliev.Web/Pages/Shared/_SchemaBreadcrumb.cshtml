@model string
@{
    bool isThai = System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName == "th";
    string language = isThai ? "th" : "en";
    string breadcrumbLabel = isThai ? "เส้นทางนำทาง" : "Breadcrumb";
    string homeName = isThai ? "หน้าแรก" : "Home";
    string servicesName = isThai ? "บริการ" : "Services";
    string serviceKey = Model ?? "CNC Machining";

    var serviceData = new Dictionary<string, (string NameTh, string NameEn, string Path)>
    {
        ["3D Printing"] = ("พิมพ์ 3D", "3D printing", "/services/3d-printing"),
        ["CNC Machining"] = ("งาน CNC", "CNC machining", "/services/cnc-machining"),
        ["3D Scanning"] = ("สแกน 3D", "3D scanning", "/services/3d-scanning"),
        ["Custom Manufacturing"] = ("ผลิตชิ้นงานตามแบบ", "Custom manufacturing", "/services/custom-manufacturing"),
    };

    var service = serviceData.TryGetValue(serviceKey, out var selectedService)
        ? selectedService
        : serviceData["CNC Machining"];
    string serviceName = isThai ? service.NameTh : service.NameEn;
    string homeUrl = CanonicalUrlPolicy.GetLocalizedUrl("/", language);
    string servicesUrl = CanonicalUrlPolicy.GetLocalizedUrl("/services", language);
    string serviceUrl = CanonicalUrlPolicy.GetLocalizedUrl(service.Path, language);

    var breadcrumbSchema = new Dictionary<string, object>
    {
        ["@context"] = "https://schema.org",
        ["@type"] = "BreadcrumbList",
        ["itemListElement"] = new object[]
        {
            new Dictionary<string, object>
            {
                ["@type"] = "ListItem",
                ["position"] = 1,
                ["name"] = homeName,
                ["item"] = homeUrl,
            },
            new Dictionary<string, object>
            {
                ["@type"] = "ListItem",
                ["position"] = 2,
                ["name"] = servicesName,
                ["item"] = servicesUrl,
            },
            new Dictionary<string, object>
            {
                ["@type"] = "ListItem",
                ["position"] = 3,
                ["name"] = serviceName,
                ["item"] = serviceUrl,
            },
        },
    };
}

<nav class="service-breadcrumb" aria-label="@breadcrumbLabel">
    <ol>
        <li><a href="@homeUrl">@homeName</a></li>
        <li><a href="@servicesUrl">@servicesName</a></li>
        <li aria-current="page">@serviceName</li>
    </ol>
</nav>
<script type="application/ld+json">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(breadcrumbSchema))</script>
