    <section id="printing-file-guide" class="service-section"><div class="service-container"><header class="service-heading center"><p class="service-eyebrow">@T("Prepare the Model", "เตรียมโมเดล")</p><h2>@T("How to prepare a file for 3D printing", "เตรียมไฟล์พิมพ์ 3 มิติอย่างไร?")</h2></header><div class="service-card-grid">
