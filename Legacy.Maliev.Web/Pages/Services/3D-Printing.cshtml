@page
@model Legacy.Maliev.Web.Pages.Services.AdditiveModel
@{
    bool isThai = System.Threading.Thread.CurrentThread.CurrentCulture.TwoLetterISOLanguageName == "th";
    Func<string, string, string> T = (en, th) => isThai ? th : en;
    ViewData["Title"] = T("3D Printing Services Bangkok & Nonthaburi | Instant Online Quote", "รับพิมพ์ 3D และรับปริ้น 3D กรุงเทพและนนทบุรี | ประเมินราคาออนไลน์");
    ViewData["Description"] = T("Order FDM and resin 3D printed parts in engineering materials. Compare material uses, prepare files, and upload CAD for instant 3D printing pricing.", "MALIEV รับพิมพ์ 3D ด้วยระบบ FDM และเรซินสำหรับต้นแบบและชิ้นงานใช้งานจริง เลือกวัสดุ อัปโหลดไฟล์ และประเมินราคาออนไลน์");
    ViewData["Keywords"] = T("3D printing service Thailand, 3D print price, order 3D print Bangkok, FDM printing, resin printing", "รับปริ้น 3D, ปริ้น 3D ราคา, ร้านปริ้น 3D, สั่งพิมพ์ 3 มิติ, พิมพ์เรซิน");
    var faqSchema = new Dictionary<string, object> {
        ["@context"] = "https://schema.org", ["@type"] = "FAQPage",
        ["mainEntity"] = new object[] {
            new Dictionary<string, object> { ["@type"] = "Question", ["name"] = T("How much does 3D printing cost?", "พิมพ์ 3D ราคาเท่าไร?"), ["acceptedAnswer"] = new Dictionary<string, object> { ["@type"] = "Answer", ["text"] = T("Cost depends on material, occupied volume, print time, support, orientation, risk, finishing, and quantity. Upload the model to MALIEV Instant Quotation for an estimate.", "ราคาขึ้นกับวัสดุ ปริมาตร เวลา ซัพพอร์ต ทิศทาง ความเสี่ยง การเก็บงาน และจำนวน อัปโหลดโมเดลในหน้าประเมินราคา MALIEV เพื่อรับราคา") } },
            new Dictionary<string, object> { ["@type"] = "Question", ["name"] = T("Can you print only one part?", "รับพิมพ์เพียง 1 ชิ้นหรือไม่?"), ["acceptedAnswer"] = new Dictionary<string, object> { ["@type"] = "Answer", ["text"] = T("Yes. MALIEV has no minimum quantity for 3D printing.", "รับพิมพ์ตั้งแต่ 1 ชิ้น ไม่มีจำนวนขั้นต่ำ") } },
            new Dictionary<string, object> { ["@type"] = "Question", ["name"] = T("Which 3D printing material is strongest?", "วัสดุพิมพ์ 3D ใดแข็งแรงที่สุด?"), ["acceptedAnswer"] = new Dictionary<string, object> { ["@type"] = "Answer", ["text"] = T("There is no single strongest material for every condition. Consider stiffness, impact, fatigue, heat, chemicals, moisture, UV, layer direction, and the required failure mode.", "ไม่มีวัสดุเดียวที่แข็งแรงที่สุดทุกสภาพ ต้องพิจารณาความแข็ง แรงกระแทก ความล้า ความร้อน สารเคมี ความชื้น UV ทิศทางชั้น และลักษณะการเสียหาย") } }
        }
    };
}

@section Head {
    <link rel="preload" as="image" href="~/src/images/services/printing/printing-hero.webp" />
}

<main class="service-page">
    <partial name="_SchemaBreadcrumb" model='"3D Printing"' />
    <section class="service-hero" aria-labelledby="printing-title">
        <img class="service-hero-media" src="~/src/images/services/printing/printing-hero.webp" width="1672" height="941" loading="eager" fetchpriority="high" decoding="async" alt="@T("Professional FDM printer producing a blue engineering fixture", "เครื่องพิมพ์ FDM กำลังผลิตฟิกซ์เจอร์วิศวกรรมสีน้ำเงิน")" />
        <div class="service-container service-hero-copy">
            <p class="service-eyebrow">@T("FDM & Resin 3D Printing", "บริการพิมพ์ FDM และเรซิน")</p>
            <h1 id="printing-title">@T("Professional 3D Printing for Prototypes and Functional Parts", "รับพิมพ์ 3D และรับปริ้น 3D สำหรับต้นแบบและชิ้นงานใช้งานจริง")</h1>
            <p class="service-hero-lead">@T("Upload your 3D model, select a material, and receive an instant estimate. We produce visual models, fit-check prototypes, jigs, fixtures, enclosures, and functional parts with FDM and resin processes.", "MALIEV รับพิมพ์ 3D ด้วยระบบ FDM และเรซิน อัปโหลดโมเดล เลือกวัสดุ และรับราคาประเมินออนไลน์สำหรับโมเดล ต้นแบบทดสอบประกอบ จิ๊ก ฟิกซ์เจอร์ กล่องครอบ และชิ้นงานใช้งานจริง")</p>
            <ul class="service-hero-points"><li><i class="fas fa-check-circle" aria-hidden="true"></i>@T("Instant online estimate", "ประเมินราคาออนไลน์ทันที")</li><li><i class="fas fa-check-circle" aria-hidden="true"></i>@T("No minimum quantity", "ไม่มีจำนวนขั้นต่ำ")</li><li><i class="fas fa-check-circle" aria-hidden="true"></i>@T("Engineering and specialty materials", "วัสดุวิศวกรรมและวัสดุเฉพาะทาง")</li></ul>
            <div class="service-actions"><a class="service-button service-button-primary" asp-page="/InstantQuotation/3D-Printing">@T("Get Instant 3D Pricing", "ประเมินราคาพิมพ์ 3D ทันที") <i class="fas fa-arrow-right" aria-hidden="true"></i></a><a class="service-button service-button-secondary" asp-page="/Quotation/Index" asp-route-item="3D-Printing">@T("Request Engineering Review", "ขอให้วิศวกรประเมิน")</a></div>
        </div>
    </section>

    <section class="service-quick"><div class="service-container service-quick-grid">
        <article><i class="fas fa-upload" aria-hidden="true"></i><div><h2>@T("Upload", "อัปโหลด")</h2><p>@T("STL, STEP, OBJ, 3MF, and supported CAD files.", "รองรับ STL, STEP, OBJ, 3MF และไฟล์ CAD")</p></div></article>
        <article><i class="fas fa-layer-group" aria-hidden="true"></i><div><h2>@T("Processes", "กระบวนการ")</h2><p>@T("FDM for durable parts; resin for fine detail and smooth surfaces.", "FDM สำหรับชิ้นงานทนทาน เรซินสำหรับรายละเอียดและผิวเรียบ")</p></div></article>
        <article><i class="fas fa-palette" aria-hidden="true"></i><div><h2>@T("Materials", "วัสดุ")</h2><p>@T("General, engineering, carbon-fiber, ESD, FR, flexible, and resin options.", "วัสดุทั่วไป วิศวกรรม คาร์บอนไฟเบอร์ ESD หน่วงไฟ ยืดหยุ่น และเรซิน")</p></div></article>
        <article><i class="fas fa-calculator" aria-hidden="true"></i><div><h2>@T("Price factors", "ปัจจัยราคา")</h2><p>@T("Geometry, material, size, support, orientation, finish, and quantity.", "รูปทรง วัสดุ ขนาด ซัพพอร์ต ทิศทาง ผิว และจำนวน")</p></div></article>
    </div></section>

    <section id="printing-processes" class="service-section"><div class="service-container"><header class="service-heading center"><p class="service-eyebrow">@T("Choose the Process", "เลือกกระบวนการ")</p><h2>@T("When should you use FDM or resin printing?", "ควรเลือกพิมพ์ FDM หรือเรซินเมื่อใด?")</h2><p>@T("The best process depends on part purpose, detail, strength, surface finish, size, material behavior, and budget.", "กระบวนการที่เหมาะสมขึ้นกับการใช้งาน รายละเอียด ความแข็งแรง ผิว ขนาด พฤติกรรมวัสดุ และงบประมาณ")</p></header><div class="service-card-grid">
        <article class="service-card"><i class="fas fa-cubes" aria-hidden="true"></i><h3>@T("FDM: functional and larger parts", "FDM: ชิ้นงานใช้งานจริงและขนาดใหญ่")</h3><p>@T("FDM builds thermoplastic parts layer by layer. It is a practical choice for fit checks, brackets, enclosures, jigs, fixtures, ducts, and low-volume functional components.", "FDM สร้างชิ้นงานเทอร์โมพลาสติกทีละชั้น เหมาะกับงานทดสอบประกอบ ขายึด กล่อง จิ๊ก ฟิกซ์เจอร์ ท่อลม และชิ้นงานใช้งานจริงจำนวนน้อย")</p></article>
        <article class="service-card"><i class="fas fa-gem" aria-hidden="true"></i><h3>@T("Resin: detail and smooth surfaces", "เรซิน: รายละเอียดสูงและผิวเรียบ")</h3><p>@T("Resin processes cure liquid photopolymer for fine features and smooth presentation surfaces. They suit detailed models, small prototypes, clear parts, flexible details, and casting patterns.", "การพิมพ์เรซินทำให้โฟโตโพลิเมอร์แข็งตัวเพื่อรายละเอียดสูงและผิวเรียบ เหมาะกับโมเดล ต้นแบบขนาดเล็ก ชิ้นงานใส ชิ้นงานยืดหยุ่น และต้นแบบงานหล่อ")</p></article>
        <article class="service-card"><i class="fas fa-balance-scale" aria-hidden="true"></i><h3>@T("A prototype is not automatically a production part", "ต้นแบบไม่ได้เท่ากับชิ้นงานผลิตเสมอไป")</h3><p>@T("Layer direction, heat, UV exposure, chemicals, impact, creep, fire, ESD, and outdoor use can change material suitability. Tell us the real environment before selecting a material.", "ทิศทางชั้น ความร้อน UV สารเคมี แรงกระแทก การคืบ ไฟฟ้าสถิต และกลางแจ้งมีผลต่อวัสดุ ควรแจ้งสภาพใช้งานจริงก่อนเลือก")</p></article>
    </div></div></section>

    <section id="printing-workflow" class="service-section service-section-soft"><div class="service-container"><header class="service-heading center"><p class="service-eyebrow">@T("How It Works", "ขั้นตอนการสั่งผลิต")</p><h2>@T("From 3D model to delivered part", "จากโมเดล 3D สู่ชิ้นงาน")</h2></header><ol class="service-process">
        <li><h3>@T("Upload the model", "อัปโหลดโมเดล")</h3><p>@T("Use the Instant Quotation page to inspect the model, dimensions, bodies, and geometry warnings.", "ใช้หน้าประเมินราคาทันทีเพื่อตรวจโมเดล ขนาด จำนวนบอดี และคำเตือนรูปทรง")</p></li>
        <li><h3>@T("Select material and quantity", "เลือกวัสดุและจำนวน")</h3><p>@T("Choose by use case, environment, required behavior, color, and budget—not only appearance.", "เลือกจากการใช้งาน สภาพแวดล้อม คุณสมบัติ สี และงบประมาณ ไม่ใช่เพียงรูปลักษณ์")</p></li>
        <li><h3>@T("Review orientation and support", "ตรวจทิศทางและซัพพอร์ต")</h3><p>@T("Orientation changes strength, visible layers, support marks, accuracy, print time, and cost.", "ทิศทางมีผลต่อความแข็งแรง รอยชั้น รอยซัพพอร์ต ความแม่นยำ เวลา และราคา")</p></li>
        <li><h3>@T("Print, finish, and deliver", "พิมพ์ เก็บงาน และจัดส่ง")</h3><p>@T("Parts are printed, supports removed, cleaned or cured as required, checked, and prepared for delivery.", "พิมพ์ชิ้นงาน ถอดซัพพอร์ต ทำความสะอาดหรืออบตามกระบวนการ ตรวจสอบ และเตรียมจัดส่ง")</p></li>
    </ol></div></section>

    <section id="printing-materials" class="service-section"><div class="service-container service-split reverse"><img class="service-split-image" src="~/src/images/services/printing/printing-materials.webp" loading="lazy" width="1536" height="1024" alt="@T("Examples of FDM and resin 3D printed parts", "ตัวอย่างชิ้นงานพิมพ์ 3D แบบ FDM และเรซิน")" /><div class="service-copy"><p class="service-eyebrow">@T("Material Catalogue", "รายการวัสดุ")</p><h2>@T("Available 3D printing materials", "วัสดุพิมพ์ 3 มิติที่มีให้เลือก")</h2><p>@T("This guide follows the materials currently selectable in MALIEV Instant Quotation. Availability, color, manufacturer grade, and special performance requirements are confirmed with the order.", "รายการนี้อ้างอิงวัสดุที่เลือกได้ในหน้าประเมินราคา MALIEV ปัจจุบัน โดยยืนยันสต็อก สี เกรดผู้ผลิต และคุณสมบัติพิเศษพร้อมคำสั่งซื้อ")</p><div class="service-actions"><a class="service-button service-button-primary" href="#material-comparison">@T("Compare and Price Materials", "เปรียบเทียบวัสดุและราคา") <i class="fas fa-arrow-down" aria-hidden="true"></i></a></div></div></div></section>

    <section class="service-section service-section-soft"><div class="service-container"><header class="service-heading center"><p class="service-eyebrow">@T("Quick comparison", "เปรียบเทียบอย่างรวดเร็ว")</p><h2>@T("Find the right 3D printing material", "ค้นหาวัสดุพิมพ์ 3 มิติที่เหมาะกับงาน")</h2><p>@T("Search by material or application, then filter by process. These are practical starting points rather than complete engineering specifications.", "ค้นหาจากชื่อวัสดุหรือลักษณะงาน แล้วกรองตามกระบวนการ ข้อมูลนี้เป็นแนวทางเบื้องต้น ไม่ใช่ข้อกำหนดทางวิศวกรรมฉบับเต็ม")</p></header>
        <div id="material-comparison" class="service-material-comparison">
            <div class="service-material-controls">
                <label class="service-material-search" for="material-search"><span>@T("Search materials", "ค้นหาวัสดุ")</span><input id="material-search" type="search" autocomplete="off" placeholder="@T("Name, property, or application", "ชื่อ คุณสมบัติ หรือลักษณะงาน")" /></label>
                <label for="material-process"><span>@T("Process", "กระบวนการ")</span><select id="material-process"><option value="all">@T("All processes", "ทุกกระบวนการ")</option><option value="fdm">FDM</option><option value="carbon">@T("Carbon fiber", "คาร์บอนไฟเบอร์")</option><option value="specialty">@T("Specialty", "วัสดุเฉพาะทาง")</option><option value="resin">@T("Resin", "เรซิน")</option></select></label>
                <button id="material-reset" class="service-material-reset" type="button">@T("Reset", "ล้างตัวกรอง")</button>
                <p id="material-result-count" class="service-material-count" aria-live="polite" data-count-template="@T("{0} materials", "{0} วัสดุ")">@T("24 materials", "24 วัสดุ")</p>
            </div>
            <div class="service-material-table-wrap">
                <table class="service-material-compare">
                    <caption class="sr-only">@T("Comparison of available 3D printing materials", "ตารางเปรียบเทียบวัสดุพิมพ์ 3 มิติที่มีให้เลือก")</caption>
                    <thead><tr><th scope="col">@T("Material", "วัสดุ")</th><th scope="col">@T("Process", "กระบวนการ")</th><th scope="col">@T("Best for", "เหมาะกับ")</th><th scope="col">@T("Advantages", "ข้อดี")</th><th scope="col">@T("Watch-outs", "ข้อควรทราบ")</th></tr></thead>
                    <tbody>
                        <tr data-material-row data-material-key="PLA" data-material-group="fdm"><th scope="row" data-label="@T("Material", "วัสดุ")"><strong>PLA</strong><small>Polylactic Acid</small></th><td data-label="@T("Process", "กระบวนการ")">FDM</td><td data-label="@T("Best for", "เหมาะกับ")">@T("Visual prototypes, models", "ต้นแบบรูปลักษณ์ โมเดล")</td><td data-label="@T("Advantages", "ข้อดี")">@T("Stable, crisp, economical", "คงรูปดี รายละเอียดคม ประหยัด")</td><td data-label="@T("Watch-outs", "ข้อควรทราบ")">@T("Low heat and impact resistance", "ทนร้อนและแรงกระแทกต่ำ")</td></tr>
                        <tr data-material-row data-material-key="PETG" data-material-group="fdm"><th scope="row" data-label="@T("Material", "วัสดุ")"><strong>PETG</strong><small>PET Glycol-modified</small></th><td data-label="@T("Process", "กระบวนการ")">FDM</td><td data-label="@T("Best for", "เหมาะกับ")">@T("General functional parts", "ชิ้นงานใช้งานทั่วไป")</td><td data-label="@T("Advantages", "ข้อดี")">@T("Tough, good layer bonding", "เหนียว ยึดเกาะชั้นดี")</td><td data-label="@T("Watch-outs", "ข้อควรทราบ")">@T("Can string; moderate heat limit", "อาจมีเส้นใย ทนร้อนปานกลาง")</td></tr>
                        <tr data-material-row data-material-key="ABS" data-material-group="fdm"><th scope="row" data-label="@T("Material", "วัสดุ")"><strong>ABS</strong><small>Acrylonitrile Butadiene Styrene</small></th><td data-label="@T("Process", "กระบวนการ")">FDM</td><td data-label="@T("Best for", "เหมาะกับ")">@T("Enclosures, fixtures", "กล่องครอบ ฟิกซ์เจอร์")</td><td data-label="@T("Advantages", "ข้อดี")">@T("Impact and heat resistant", "ทนกระแทกและความร้อน")</td><td data-label="@T("Watch-outs", "ข้อควรทราบ")">@T("Warping and shrinkage", "บิดงอและหดตัว")</td></tr>
                        <tr data-material-row data-material-key="ASA" data-material-group="fdm"><th scope="row" data-label="@T("Material", "วัสดุ")"><strong>ASA</strong><small>Acrylonitrile Styrene Acrylate</small></th><td data-label="@T("Process", "กระบวนการ")">FDM</td><td data-label="@T("Best for", "เหมาะกับ")">@T("Outdoor housings", "กล่องและชิ้นงานกลางแจ้ง")</td><td data-label="@T("Advantages", "ข้อดี")">@T("UV and weather resistant", "ทน UV และสภาพอากาศ")</td><td data-label="@T("Watch-outs", "ข้อควรทราบ")">@T("Warping; enclosed print needed", "บิดงอ ต้องควบคุมการพิมพ์")</td></tr>
                        <tr data-material-row data-material-key="HIPS" data-material-group="fdm"><th scope="row" data-label="@T("Material", "วัสดุ")"><strong>HIPS</strong><small>High Impact Polystyrene</small></th><td data-label="@T("Process", "กระบวนการ")">FDM</td><td data-label="@T("Best for", "เหมาะกับ")">@T("Light parts, ABS support", "ชิ้นงานเบา ซัพพอร์ต ABS")</td><td data-label="@T("Advantages", "ข้อดี")">@T("Easy to sand and machine", "ขัดแต่งและตัดเฉือนได้ง่าย")</td><td data-label="@T("Watch-outs", "ข้อควรทราบ")">@T("Lower strength; can warp", "ความแข็งแรงต่ำกว่า อาจบิดงอ")</td></tr>
                        <tr data-material-row data-material-key="TPU" data-material-group="fdm"><th scope="row" data-label="@T("Material", "วัสดุ")"><strong>TPU</strong><small>Flexible Polyurethane</small></th><td data-label="@T("Process", "กระบวนการ")">FDM</td><td data-label="@T("Best for", "เหมาะกับ")">@T("Grips, guards, seals", "ด้ามจับ การ์ด ซีล")</td><td data-label="@T("Advantages", "ข้อดี")">@T("Flexible and impact tolerant", "ยืดหยุ่นและทนกระแทก")</td><td data-label="@T("Watch-outs", "ข้อควรทราบ")">@T("Slow print; limited stiffness", "พิมพ์ช้า ความแข็งต่ำ")</td></tr>
                        <tr data-material-row data-material-key="PC" data-material-group="fdm"><th scope="row" data-label="@T("Material", "วัสดุ")"><strong>PC</strong><small>Polycarbonate</small></th><td data-label="@T("Process", "กระบวนการ")">FDM</td><td data-label="@T("Best for", "เหมาะกับ")">@T("Demanding mechanical parts", "ชิ้นส่วนกลไกรับงานหนัก")</td><td data-label="@T("Advantages", "ข้อดี")">@T("Strong, heat and impact resistant", "แข็งแรง ทนร้อนและกระแทก")</td><td data-label="@T("Watch-outs", "ข้อควรทราบ")">@T("Moisture and warp sensitive", "ไวต่อความชื้นและบิดงอ")</td></tr>
