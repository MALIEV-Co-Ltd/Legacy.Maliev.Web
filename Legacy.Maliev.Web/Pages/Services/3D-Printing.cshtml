@page
@model Legacy.Maliev.Web.Pages.Services.AdditiveModel
@using Legacy.Maliev.Web.Components.Pages.Services
@using Legacy.Maliev.Web.Components.Metadata
@{
    bool isThai = System.Threading.Thread.CurrentThread.CurrentCulture.TwoLetterISOLanguageName == "th";
    Func<string, string, string> T = (en, th) => isThai ? th : en;
    ViewData["Title"] = T("3D Printing Services Bangkok & Nonthaburi | Instant Online Quote", "รับพิมพ์ 3D และรับปริ้น 3D กรุงเทพและนนทบุรี | ประเมินราคาออนไลน์");
    ViewData["Description"] = T("Order FDM and resin 3D printed parts in engineering materials. Compare material uses, prepare files, and upload CAD for instant 3D printing pricing.", "MALIEV รับพิมพ์ 3D ด้วยระบบ FDM และเรซินสำหรับต้นแบบและชิ้นงานใช้งานจริง เลือกวัสดุ อัปโหลดไฟล์ และประเมินราคาออนไลน์");
    ViewData["Keywords"] = T("3D printing service Thailand, 3D print price, order 3D print Bangkok, FDM printing, resin printing", "รับปริ้น 3D, ปริ้น 3D ราคา, ร้านปริ้น 3D, สั่งพิมพ์ 3 มิติ, พิมพ์เรซิน");
    var faqJson = ThreeDimensionalPrintingPage.CreateFaqJson();
}

@section Head {
    <link rel="preload" as="image" href="~/src/images/services/printing/printing-hero.webp" />
}

<component type="typeof(ThreeDimensionalPrintingContent)" render-mode="Static" />

@section Schema { <component type="typeof(PublicServiceStructuredData)" render-mode="Static" param-Model="@(PublicServiceStructuredDataDisplayModel.Create("3D Printing"))" /><script type="application/ld+json">@Html.Raw(faqJson)</script> }
