@page
@model Legacy.Maliev.Web.Pages.Services.Machining
@using Legacy.Maliev.Web.Components.Shared
@{
    bool isThai = System.Threading.Thread.CurrentThread.CurrentCulture.TwoLetterISOLanguageName == "th";
    Func<string, string, string> T = (en, th) => isThai ? th : en;
    ViewData["Title"] = T("CNC Machining Services in Bangkok & Nonthaburi | One-Off and Production Parts", "รับงาน CNC ตามแบบ กรุงเทพและนนทบุรี | งานชิ้นเดียวถึงงานผลิต");
    ViewData["Description"] = T("CNC milling and turning for one-off parts, prototypes, jigs and production. Common JIS metals and engineering plastics. Send CAD and drawings for a quote.", "MALIEV รับผลิตชิ้นงาน CNC ตามไฟล์ CAD และแบบงาน ตั้งแต่งานชิ้นเดียว ต้นแบบ จิ๊ก ไปจนถึงงานผลิตซ้ำ รองรับโลหะและพลาสติกวิศวกรรม");
    ViewData["Keywords"] = T("CNC machining Thailand, CNC aluminum, CNC one piece, machine shop Bangkok, CNC Nonthaburi", "รับ CNC อลูมิเนียม, รับกลึง CNC, โรงกลึง นนทบุรี, CNC งานชิ้นเดียว, โรงงาน CNC");
    var faqSchema = new Dictionary<string, object> {
        ["@context"] = "https://schema.org", ["@type"] = "FAQPage",
        ["mainEntity"] = new object[] {
            new Dictionary<string, object> { ["@type"] = "Question", ["name"] = T("Can you machine only one piece?", "รับทำ CNC เพียง 1 ชิ้นหรือไม่?"), ["acceptedAnswer"] = new Dictionary<string, object> { ["@type"] = "Answer", ["text"] = T("Yes. MALIEV accepts feasible one-off CNC parts. Setup and programming are distributed across quantity, so unit price often improves with repeat quantities.", "รับงาน CNC ชิ้นเดียวเมื่อผลิตได้จริง โดยค่าเตรียมเครื่องและเขียนโปรแกรมเฉลี่ยตามจำนวน ทำให้ราคาต่อชิ้นมักดีขึ้นเมื่อผลิตหลายชิ้น") } },
            new Dictionary<string, object> { ["@type"] = "Question", ["name"] = T("How much does CNC machining cost?", "งาน CNC ราคาเท่าไร?"), ["acceptedAnswer"] = new Dictionary<string, object> { ["@type"] = "Answer", ["text"] = T("Cost depends on material, part size, machining time, setups, tooling, tolerances, finish, inspection, and quantity. Send CAD and a drawing for a quotation.", "ราคาขึ้นกับวัสดุ ขนาด เวลาเครื่อง การจับยึด เครื่องมือ ค่าคลาดเคลื่อน ผิว การตรวจสอบ และจำนวน ควรส่ง CAD และแบบงานเพื่อเสนอราคา") } },
            new Dictionary<string, object> { ["@type"] = "Question", ["name"] = T("What files should I send for CNC machining?", "ควรส่งไฟล์อะไรสำหรับงาน CNC?"), ["acceptedAnswer"] = new Dictionary<string, object> { ["@type"] = "Answer", ["text"] = T("Send a usable solid CAD file such as STEP for geometry and a PDF drawing for critical dimensions, tolerances, threads, fits, finish, and inspection notes.", "ส่งไฟล์ solid CAD เช่น STEP สำหรับรูปทรง และแบบ PDF ระบุขนาดสำคัญ ค่าคลาดเคลื่อน เกลียว ฟิต ผิว และจุดตรวจสอบ") } }
        }
    };
}

@section Head {
    <link rel="preload" as="image" href="~/src/images/services/cnc/cnc-hero.webp" />
}

<main class="service-page">
    <component type="typeof(ServiceBreadcrumb)" render-mode="Static" param-ServiceKey='"CNC Machining"' />
    <section class="service-hero" aria-labelledby="cnc-title">
        <img class="service-hero-media" src="~/src/images/services/cnc/cnc-hero.webp" width="1672" height="941" loading="eager" fetchpriority="high" decoding="async" alt="@T("CNC milling an aluminum component held in a machine vise", "เครื่อง CNC กำลังกัดชิ้นงานอะลูมิเนียมที่ยึดในปากกาอย่างมั่นคง")" />
        <div class="service-container service-hero-copy">
            <p class="service-eyebrow">@T("CNC Milling & Turning", "บริการ CNC Milling และ Turning")</p>
            <h1 id="cnc-title">@T("Precision CNC Machining for One-Off and Production Parts", "รับงาน CNC ตามแบบ ตั้งแต่งานชิ้นเดียวถึงงานผลิต")</h1>
            <p class="service-hero-lead">@T("We machine custom metal and engineering-plastic parts from your CAD model and drawing. MALIEV supports prototypes, replacement parts, jigs, fixtures, and repeat production for customers in Bangkok, Nonthaburi, and across Thailand.", "MALIEV รับผลิตชิ้นงาน CNC ตามไฟล์ CAD และแบบงาน ทั้งโลหะและพลาสติกวิศวกรรม รองรับต้นแบบ อะไหล่ทดแทน จิ๊ก ฟิกซ์เจอร์ และงานผลิตซ้ำ สำหรับลูกค้าในกรุงเทพ นนทบุรี และทั่วประเทศไทย")</p>
            <ul class="service-hero-points"><li><i class="fas fa-check-circle" aria-hidden="true"></i>@T("One piece welcome", "รับงานชิ้นเดียว")</li><li><i class="fas fa-check-circle" aria-hidden="true"></i>@T("Metals and engineering plastics", "โลหะและพลาสติกวิศวกรรม")</li><li><i class="fas fa-check-circle" aria-hidden="true"></i>@T("Engineering review before production", "วิศวกรตรวจสอบก่อนผลิต")</li></ul>
            <div class="service-actions">
                <a class="service-button service-button-primary" asp-area="" asp-page="/Quotation/Index" asp-route-item="CNC-Machining">@T("Request a CNC Quote", "ขอใบเสนอราคา CNC") <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
                <a class="service-button service-button-secondary" asp-page="/Contact/Index">@T("Discuss Your Part", "ปรึกษางานกับเรา")</a>
            </div>
        </div>
    </section>

    <section class="service-quick"><div class="service-container service-quick-grid">
        <article><i class="fas fa-cube" aria-hidden="true"></i><div><h2>@T("Order size", "จำนวนสั่งผลิต")</h2><p>@T("One-off parts through repeat production.", "ตั้งแต่งานชิ้นเดียวถึงงานผลิตซ้ำ")</p></div></article>
        <article><i class="fas fa-file-alt" aria-hidden="true"></i><div><h2>@T("Best quote input", "ข้อมูลที่ควรส่ง")</h2><p>@T("3D CAD, drawing, material, quantity, and finish.", "ไฟล์ 3D แบบงาน วัสดุ จำนวน และผิวสำเร็จ")</p></div></article>
        <article><i class="fas fa-cogs" aria-hidden="true"></i><div><h2>@T("Processes", "กระบวนการ")</h2><p>@T("CNC milling and turning, reviewed per geometry.", "CNC Milling และ Turning ตามรูปทรงชิ้นงาน")</p></div></article>
        <article><i class="fas fa-map-marker-alt" aria-hidden="true"></i><div><h2>@T("Service area", "พื้นที่ให้บริการ")</h2><p>@T("Bangkok, Nonthaburi, and delivery across Thailand.", "กรุงเทพ นนทบุรี และจัดส่งทั่วไทย")</p></div></article>
    </div></section>

    <section id="cnc-capabilities" class="service-section"><div class="service-container">
        <header class="service-heading center"><p class="service-eyebrow">@T("Capabilities", "ความสามารถการผลิต")</p><h2>@T("What can CNC machining make?", "CNC เหมาะกับการผลิตอะไร?")</h2><p>@T("CNC machining removes material from solid stock to produce repeatable features, accurate interfaces, and durable functional parts.", "CNC เป็นกระบวนการตัดเนื้อวัสดุออกจากวัตถุดิบตัน เพื่อสร้างชิ้นงานใช้งานจริงที่มีรูปทรงและตำแหน่งประกอบสม่ำเสมอ")</p></header>
        <div class="service-card-grid">
            <article class="service-card service-card-visual"><img class="service-card-media" src="~/src/images/services/cnc/cards/cnc-card-milled-parts.webp" loading="lazy" width="960" height="640" alt="@T("Precision-milled aluminum brackets and housings beside a machining center", "ขายึดและตัวเรือนอะลูมิเนียมกัดละเอียดข้างเครื่องแมชชีนนิ่งเซ็นเตอร์")" /><div class="service-card-body"><h3>@T("Milled parts", "ชิ้นงานกัด")</h3><p>@T("Brackets, housings, plates, pockets, mounting faces, slots, and drilled or tapped features where tools can reach.", "ขายึด ตัวเรือน เพลท ร่อง ผิวประกอบ รูเจาะ และรูเกลียวในตำแหน่งที่เครื่องมือตัดเข้าถึงได้")</p></div></article>
            <article class="service-card service-card-visual"><img class="service-card-media" src="~/src/images/services/cnc/cards/cnc-card-turned-parts.webp" loading="lazy" width="960" height="640" alt="@T("CNC-turned shafts, bushes, spacers, and threaded pins beside a lathe", "เพลา บูช สเปเซอร์ และพินเกลียวที่กลึง CNC ข้างเครื่องกลึง")" /><div class="service-card-body"><h3>@T("Turned parts", "ชิ้นงานกลึง")</h3><p>@T("Shafts, bushes, spacers, pins, threaded components, and other rotationally symmetric parts.", "เพลา บูช สเปเซอร์ พิน ชิ้นส่วนเกลียว และชิ้นงานทรงหมุน")</p></div></article>
            <article class="service-card service-card-visual"><img class="service-card-media" src="~/src/images/services/cnc/cards/cnc-card-jigs-fixtures.webp" loading="lazy" width="960" height="640" alt="@T("A custom inspection fixture with toggle clamps and a dial indicator", "ฟิกซ์เจอร์ตรวจสอบเฉพาะงานพร้อมแคลมป์และไดอัลอินดิเคเตอร์")" /><div class="service-card-body"><h3>@T("Jigs and fixtures", "จิ๊กและฟิกซ์เจอร์")</h3><p>@T("Production aids, inspection fixtures, machine adapters, and custom tooling built around your real process.", "อุปกรณ์ช่วยผลิต ฟิกซ์เจอร์ตรวจสอบ อะแดปเตอร์ และเครื่องมือเฉพาะสำหรับกระบวนการของคุณ")</p></div></article>
            <article class="service-card service-card-visual"><img class="service-card-media" src="~/src/images/services/cnc/cards/cnc-card-replacement-parts.webp" loading="lazy" width="960" height="640" alt="@T("A worn industrial gear beside its newly machined replacement", "เฟืองอุตสาหกรรมที่สึกวางคู่กับอะไหล่ใหม่ที่กัดขึ้นทดแทน")" /><div class="service-card-body"><h3>@T("Replacement parts", "อะไหล่ทดแทน")</h3><p>@T("Recreate discontinued or damaged components from usable drawings, CAD, samples, or measurement data after feasibility review.", "ผลิตอะไหล่ที่เลิกผลิตหรือเสียหายจากแบบ CAD ตัวอย่าง หรือข้อมูลการวัด เมื่อผ่านการประเมินความเป็นไปได้")</p></div></article>
            <article class="service-card service-card-visual"><img class="service-card-media" src="~/src/images/services/cnc/cards/cnc-card-functional-prototype.webp" loading="lazy" width="960" height="640" alt="@T("Hands test-fitting a functional machined prototype assembly", "มือกำลังทดสอบประกอบต้นแบบอะลูมิเนียมที่ผลิตเพื่อใช้งานจริง")" /><div class="service-card-body"><h3>@T("Functional prototypes", "ต้นแบบใช้งานจริง")</h3><p>@T("Test fit, assembly, motion, sealing interfaces, and material behavior before committing to a larger production run.", "ทดสอบการประกอบ การเคลื่อนไหว ผิวซีล และพฤติกรรมวัสดุก่อนเริ่มงานจำนวนมาก")</p></div></article>
            <article class="service-card service-card-visual"><img class="service-card-media" src="~/src/images/services/cnc/cards/cnc-card-repeat-production.webp" loading="lazy" width="960" height="640" alt="@T("A batch of repeat CNC parts being checked with digital calipers", "ชิ้นงาน CNC ผลิตซ้ำเป็นชุดกำลังตรวจสอบด้วยดิจิทัลคาลิปเปอร์")" /><div class="service-card-body"><h3>@T("Repeat production", "งานผลิตซ้ำ")</h3><p>@T("Controlled drawings and approved samples help keep repeat orders consistent; inspection scope is agreed during quotation.", "แบบควบคุมและตัวอย่างอนุมัติช่วยให้งานสั่งซ้ำสม่ำเสมอ โดยตกลงขอบเขตการตรวจสอบในขั้นเสนอราคา")</p></div></article>
        </div>
    </div></section>

    <section id="cnc-process" class="service-section service-section-soft"><div class="service-container">
        <header class="service-heading center"><p class="service-eyebrow">@T("From CAD to Part", "จากไฟล์ CAD สู่ชิ้นงาน")</p><h2>@T("How the CNC quotation and production process works", "ขั้นตอนขอราคาและผลิตชิ้นงาน CNC")</h2></header>
        <ol class="service-process">
            <li><h3>@T("Send project files", "ส่งข้อมูลโครงการ")</h3><p>@T("Provide 3D CAD, a dimensioned drawing, material, quantity, finish, and required delivery date.", "ส่งไฟล์ 3D แบบระบุขนาด วัสดุ จำนวน ผิวสำเร็จ และวันที่ต้องการ")</p></li>
            <li><h3>@T("Engineering review", "วิศวกรตรวจสอบ")</h3><p>@T("We review tool access, tolerances, setups, stock availability, inspection, and manufacturability questions.", "ตรวจสอบการเข้าถึงของเครื่องมือ ค่าคลาดเคลื่อน จำนวนครั้งจับยึด วัตถุดิบ และการตรวจสอบ")</p></li>
            <li><h3>@T("Quote and confirmation", "เสนอราคาและยืนยัน")</h3><p>@T("The quotation confirms scope, material, quantity, lead time, finish, and any assumptions requiring approval.", "ใบเสนอราคาระบุขอบเขต วัสดุ จำนวน ระยะเวลา ผิวสำเร็จ และเงื่อนไขที่ต้องยืนยัน")</p></li>
            <li><h3>@T("Machine, inspect, deliver", "ผลิต ตรวจสอบ และจัดส่ง")</h3><p>@T("Parts are machined to the approved files, checked to the agreed inspection scope, and prepared for delivery.", "ผลิตตามไฟล์ที่อนุมัติ ตรวจสอบตามขอบเขตที่ตกลง และเตรียมจัดส่ง")</p></li>
        </ol>
    </div></section>

    <section id="cnc-materials" class="service-section"><div class="service-container service-split">
        <div class="service-copy"><p class="service-eyebrow">@T("Materials", "วัสดุ")</p><h2>@T("Common JIS metals and engineering plastics", "โลหะมาตรฐาน JIS และพลาสติกวิศวกรรมที่ใช้บ่อย")</h2><p>@T("Choose a material by strength, corrosion resistance, wear, temperature, weight, appearance, and cost—not by name alone. Exact grade, stock form, certificates, heat treatment, and availability are confirmed during quotation.", "ควรเลือกวัสดุจากความแข็งแรง การกัดกร่อน การสึกหรอ อุณหภูมิ น้ำหนัก รูปลักษณ์ และต้นทุน ไม่ใช่จากชื่อเพียงอย่างเดียว เกรด รูปแบบวัตถุดิบ ใบรับรอง การอบชุบ และสต็อกจะยืนยันในขั้นเสนอราคา")</p><div class="service-note">@T("MALIEV machines metals and engineering plastics. We do not offer CNC machining of wood or organic materials.", "MALIEV รับผลิตโลหะและพลาสติกวิศวกรรมด้วย CNC ไม่รับงานไม้หรือวัสดุอินทรีย์")</div></div>
        <img class="service-split-image" src="~/src/images/services/cnc/cnc-materials.webp" loading="lazy" width="1536" height="1024" alt="@T("CNC-machined metal and engineering-plastic samples", "ตัวอย่างชิ้นงาน CNC จากโลหะและพลาสติกวิศวกรรม")" />
    </div></section>

    <section class="service-section service-section-soft"><div class="service-container"><div class="service-material-grid">
        <article class="service-material"><h3>@T("Aluminium alloys", "อะลูมิเนียมอัลลอย")</h3><p>@T("Lightweight, corrosion resistant, and efficient to machine. Often selected for housings, brackets, fixtures, and automation parts.", "น้ำหนักเบา ทนการกัดกร่อน และตัดเฉือนได้ดี เหมาะกับตัวเรือน ขายึด ฟิกซ์เจอร์ และชิ้นส่วนระบบอัตโนมัติ")</p></article>
        <article class="service-material"><h3>@T("Carbon steels: SS400 and S50C", "เหล็กคาร์บอน SS400 และ S50C")</h3><p>@T("SS400 suits general structural components; S50C provides higher carbon content for stronger machine parts when appropriately processed.", "SS400 เหมาะกับชิ้นส่วนโครงสร้างทั่วไป ส่วน S50C มีคาร์บอนสูงกว่า เหมาะกับชิ้นส่วนเครื่องจักรตามการอบชุบที่กำหนด")</p></article>
        <article class="service-material"><h3>@T("Alloy steels: SCM families", "เหล็กอัลลอยกลุ่ม SCM")</h3><p>@T("Used when strength, toughness, fatigue, or heat-treatment response matters. The exact SCM grade and condition must be specified.", "ใช้เมื่อต้องการความแข็งแรง ความเหนียว ความทนล้า หรือการตอบสนองต่อการอบชุบ ต้องระบุเกรดและสภาพวัสดุ")</p></article>
        <article class="service-material"><h3>@T("Tool steels: SKD families", "เหล็กเครื่องมือกลุ่ม SKD")</h3><p>@T("For tooling and wear-resistant applications. Machining route depends strongly on grade, supplied hardness, and required heat treatment.", "เหมาะกับเครื่องมือและงานทนสึก กระบวนการผลิตขึ้นกับเกรด ความแข็งขณะรับเข้า และการอบชุบที่ต้องการ")</p></article>
        <article class="service-material"><h3>@T("Stainless steels: SUS families", "สแตนเลสกลุ่ม SUS")</h3><p>@T("Selected for corrosion resistance, cleanliness, or appearance. Grade choice affects machinability, strength, and environmental resistance.", "เลือกใช้เพื่อทนการกัดกร่อน ความสะอาด หรือรูปลักษณ์ โดยเกรดมีผลต่อการตัดเฉือน ความแข็งแรง และสภาพแวดล้อมใช้งาน")</p></article>
        <article class="service-material"><h3>@T("POM / Acetal", "POM / อะซีทัล")</h3><p>@T("Dimensionally stable, low-friction engineering plastic for gears, guides, bushings, and precision mechanisms.", "พลาสติกวิศวกรรมคงรูปดีและแรงเสียดทานต่ำ เหมาะกับเฟือง รางนำ บูช และกลไกความแม่นยำ")</p></article>
        <article class="service-material"><h3>@T("MC Nylon / PA6", "MC Nylon / PA6")</h3><p>@T("Tough and wear resistant for rollers, guides, pads, and replacement machine components; moisture response must be considered.", "เหนียวและทนสึก เหมาะกับลูกกลิ้ง ราง แผ่นรอง และอะไหล่เครื่องจักร โดยต้องคำนึงถึงการดูดความชื้น")</p></article>
        <article class="service-material"><h3>@T("Acrylic and PVC", "อะคริลิกและ PVC")</h3><p>@T("Acrylic suits clear covers and visual parts; PVC suits selected chemical or utility applications. Geometry and clamping need care.", "อะคริลิกเหมาะกับฝาครอบใสและชิ้นงานโชว์ ส่วน PVC เหมาะกับงานเคมีหรือใช้งานเฉพาะ การจับยึดและรูปทรงต้องระมัดระวัง")</p></article>
        <article class="service-material"><h3>@T("PTFE / Teflon", "PTFE / Teflon")</h3><p>@T("Very low friction and strong chemical resistance for seals, insulators, and sliding components; softness affects tolerance strategy.", "แรงเสียดทานต่ำและทนสารเคมี เหมาะกับซีล ฉนวน และชิ้นส่วนเลื่อน แต่ความนิ่มมีผลต่อการกำหนดค่าคลาดเคลื่อน")</p></article>
    </div></div></section>

    <section id="cnc-design-guide" class="service-section"><div class="service-container"><header class="service-heading center"><p class="service-eyebrow">@T("Design for Machining", "ออกแบบเพื่อการผลิต")</p><h2>@T("What information improves CNC price and lead-time accuracy?", "ข้อมูลใดช่วยให้ราคาและระยะเวลาผลิตแม่นยำขึ้น?")</h2></header><div class="service-card-grid">
        <article class="service-card"><i class="fas fa-file-signature" aria-hidden="true"></i><h3>@T("Send CAD and a drawing", "ส่ง CAD พร้อมแบบงาน")</h3><p>@T("Use 3D CAD for geometry and a 2D drawing for critical dimensions, tolerances, threads, fits, surface finish, and inspection notes.", "ใช้ไฟล์ 3D กำหนดรูปทรง และแบบ 2D ระบุขนาดสำคัญ ค่าคลาดเคลื่อน เกลียว ฟิต ผิว และจุดตรวจสอบ")</p></article>
        <article class="service-card"><i class="fas fa-ruler-combined" aria-hidden="true"></i><h3>@T("Apply tolerances selectively", "กำหนดค่าคลาดเคลื่อนเท่าที่จำเป็น")</h3><p>@T("Tighter tolerances can require more setups, slower machining, controlled temperature, and additional inspection. Mark only functional features tightly.", "ค่าคลาดเคลื่อนแคบอาจเพิ่มการจับยึด เวลา การควบคุมอุณหภูมิ และการตรวจสอบ ควรกำหนดเฉพาะจุดที่มีผลต่อการใช้งาน")</p></article>
        <article class="service-card"><i class="fas fa-route" aria-hidden="true"></i><h3>@T("Allow tool access", "เผื่อทางเข้าของเครื่องมือ")</h3><p>@T("Deep pockets, narrow slots, sharp internal corners, thin walls, and hidden features may need special tools or redesign.", "โพ็อกเก็ตลึก ร่องแคบ มุมในคม ผนังบาง และฟีเจอร์ที่บังอาจต้องใช้เครื่องมือพิเศษหรือปรับแบบ")</p></article>
    </div></div></section>

    <section id="cnc-guides" class="service-section"><div class="service-container"><header class="service-heading center"><p class="service-eyebrow">@T("MALIEV CNC Guides", "คู่มืองาน CNC จาก MALIEV")</p><h2>@T("Resolve common drawing questions before quotation", "เตรียมรายละเอียดแบบงาน CNC ก่อนขอราคา")</h2><p>@T("These guides explain design details that affect tooling, setup, inspection, and manufacturing cost.", "คู่มือเหล่านี้อธิบายรายละเอียดที่มีผลต่อเครื่องมือ การจับยึด การตรวจสอบ และต้นทุนผลิต")</p></header><div class="service-card-grid">
        <article class="service-card"><h3>@T("Specify threaded holes", "ระบุรูเกลียวให้ผลิตและตรวจสอบได้")</h3><p>@T("Define thread standard, size, class, depth, and inspection needs instead of leaving the machinist to infer them.", "ระบุมาตรฐาน ขนาด คลาส ความลึก และวิธีตรวจสอบ แทนการให้ผู้ผลิตตีความเอง")</p><p><a href="https://shop.maliev.com/blogs/news/specify-threaded-holes-cnc-machining">@T("Read the threaded-hole guide", "อ่านคู่มือการระบุรูเกลียว")</a></p></article>
        <article class="service-card"><h3>@T("Design internal corner radii", "ออกแบบรัศมีมุมในงานกัด CNC")</h3><p>@T("Learn why rotating cutters leave a radius and how mating parts, reliefs, and tool size affect the design.", "เข้าใจเหตุผลที่ดอกกัดทิ้งรัศมี และผลของชิ้นส่วนประกบ ร่องหลบ และขนาดเครื่องมือ")</p><p><a href="https://shop.maliev.com/blogs/news/cnc-internal-corners-radius-mating-parts">@T("Read the internal-corner guide", "อ่านคู่มือมุมในงาน CNC")</a></p></article>
        <article class="service-card"><h3>@T("Plan machinable thin walls", "ออกแบบผนังบางให้ผลิตได้")</h3><p>@T("Review wall support, workholding, tool access, cutting sequence, and inspection before committing to a fragile geometry.", "พิจารณาการรองรับ การจับยึด การเข้าถึงของเครื่องมือ ลำดับตัด และการตรวจสอบก่อนยืนยันรูปทรงผนังบาง")</p><p><a href="https://shop.maliev.com/blogs/news/cnc-thin-wall-design-workholding">@T("Read the thin-wall guide", "อ่านคู่มือผนังบาง")</a></p></article>
    </div></div></section>

    <section id="cnc-faq" class="service-section service-section-soft"><div class="service-container"><header class="service-heading center"><p class="service-eyebrow">@T("CNC Machining FAQ", "คำถามงาน CNC")</p><h2>@T("Questions customers ask before ordering", "คำถามที่ลูกค้าถามก่อนสั่งผลิต")</h2></header><div class="service-faq">
        <details><summary>@T("Can you machine only one piece?", "รับทำ CNC เพียง 1 ชิ้นหรือไม่?")</summary><p>@T("Yes. We accept one-off parts when the geometry, material, and project scope are feasible. Setup and programming are distributed across the quantity, so unit price usually improves with repeat quantities.", "รับงานชิ้นเดียวเมื่อรูปทรง วัสดุ และขอบเขตงานผลิตได้จริง ค่าเตรียมเครื่องและเขียนโปรแกรมจะเฉลี่ยตามจำนวน ดังนั้นราคาต่อชิ้นมักลดลงเมื่อผลิตหลายชิ้น")</p></details>
        <details><summary>@T("How much does CNC machining cost?", "งาน CNC ราคาเท่าไร?")</summary><p>@T("CNC machining starts at THB 2,500. The final price depends on material and stock, part size, machining time, number of setups, tooling, tolerances, finish, inspection, and quantity. Send CAD and a drawing for an accurate quotation.", "งาน CNC เริ่มต้น 2,500 บาท ราคาสุดท้ายขึ้นกับวัสดุและสต็อก ขนาดชิ้นงาน เวลาเครื่อง จำนวนครั้งจับยึด เครื่องมือ ค่าคลาดเคลื่อน ผิว การตรวจสอบ และจำนวน ควรส่ง CAD และแบบงานเพื่อประเมินราคาอย่างแม่นยำ")</p></details>
        <details><summary>@T("What is the usual CNC machining lead time?", "งาน CNC ใช้เวลาผลิตเท่าไร?")</summary><p>@T("Lead time usually starts at about 14 days. The schedule includes material sourcing, CAM preparation and programming, machine setup and loading, machining, and final inspection—not only the time when material is being cut.", "ระยะเวลาผลิตโดยทั่วไปเริ่มต้นประมาณ 14 วัน เพราะรวมการจัดหาวัสดุ การเตรียม CAM และเขียนโปรแกรม การตั้งเครื่องและโหลดวัสดุ การผลิต และการตรวจสอบขั้นสุดท้าย ไม่ได้มีเฉพาะเวลาที่เครื่องกำลังตัดชิ้นงาน")</p></details>
        <details><summary>@T("Are rush CNC orders available?", "มีบริการเร่งด่วนสำหรับงาน CNC หรือไม่?")</summary><p>@T("Rush orders may be possible when machine capacity, material availability, tooling, geometry, and inspection requirements allow. An additional markup applies because the job must be prioritized and the production plan adjusted. Ask us to confirm feasibility before relying on a rush date.", "อาจรับงานเร่งด่วนได้เมื่อกำลังการผลิต วัสดุ เครื่องมือ รูปทรง และข้อกำหนดการตรวจสอบเอื้ออำนวย โดยมีค่าบริการเพิ่มเนื่องจากต้องจัดลำดับงานและปรับแผนการผลิต กรุณาให้เรายืนยันก่อนวางแผนตามกำหนดเร่งด่วน")</p></details>
        <details><summary>@T("What file formats should I send?", "ควรส่งไฟล์อะไร?")</summary><p>@T("A STEP or other usable solid CAD file is preferred for geometry, together with a PDF drawing for critical manufacturing requirements. Contact us if only a sample or legacy drawing is available.", "แนะนำไฟล์ STEP หรือไฟล์ solid CAD พร้อมแบบ PDF ระบุข้อกำหนดสำคัญ หากมีเพียงตัวอย่างหรือแบบเก่า โปรดปรึกษาเรา")</p></details>
        <details><summary>@T("Can you copy an existing part?", "สามารถลอกแบบชิ้นส่วนเดิมได้หรือไม่?")</summary><p>@T("Often yes, but the correct route may include measurement or 3D scanning, reverse engineering, material identification, and a review of wear or damage. The original design intent cannot always be recovered from a worn sample.", "หลายกรณีทำได้ แต่อาจต้องวัดหรือสแกน 3D ทำ Reverse Engineering ตรวจชนิดวัสดุ และประเมินการสึกหรอ ไม่สามารถกู้เจตนาการออกแบบเดิมทั้งหมดจากชิ้นงานที่สึกได้เสมอ")</p></details>
        <details><summary>@T("Do you guarantee the same tolerance for every feature?", "ทุกฟีเจอร์ใช้ค่าคลาดเคลื่อนเดียวกันหรือไม่?")</summary><p>@T("No. Achievable tolerance depends on geometry, size, material, setup, process, and inspection method. Critical tolerances must be identified and agreed before production.", "ไม่ใช่ ค่าที่ทำได้ขึ้นกับรูปทรง ขนาด วัสดุ การจับยึด กระบวนการ และวิธีตรวจ ต้องระบุและตกลงจุดสำคัญก่อนผลิต")</p></details>
    </div></div></section>

    <component type="typeof(ServiceLocation)" render-mode="Static" />

    <section class="service-cta-wrap"><div class="service-container service-cta"><div><h2>@T("Have a CNC part ready to review?", "มีชิ้นงาน CNC ให้เราประเมินหรือยัง?")</h2><p>@T("Send your CAD, drawing, material, and quantity. Our team will review the manufacturing requirements.", "ส่งไฟล์ CAD แบบงาน วัสดุ และจำนวน ทีมงานจะตรวจสอบข้อกำหนดการผลิต")</p></div><div class="service-actions"><a class="service-button service-button-yellow" asp-page="/Quotation/Index" asp-route-item="CNC-Machining">@T("Request a Quote", "ขอใบเสนอราคา") <i class="fas fa-arrow-right" aria-hidden="true"></i></a></div></div></section>
