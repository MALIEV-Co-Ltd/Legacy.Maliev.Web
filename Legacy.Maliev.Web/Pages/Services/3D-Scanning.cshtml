@page
@model Legacy.Maliev.Web.Pages.Services.ScanningModel
@using Legacy.Maliev.Web.Components.Pages.Services
@using Legacy.Maliev.Web.Components.Metadata
@{
    bool isThai = System.Threading.Thread.CurrentThread.CurrentCulture.TwoLetterISOLanguageName == "th";
    Func<string, string, string> T = (en, th) => isThai ? th : en;
    ViewData["Title"] = T("3D Scanning, Reverse Engineering & Deviation Analysis | Onsite Thailand", "รับสแกน 3D และ Reverse Engineering | ในสถานที่และนอกสถานที่");
    ViewData["Description"] = T("In-house and onsite 3D scanning in Thailand. Understand raw meshes, reverse-engineered CAD, deviation analysis, preparation, limitations, and deliverable files.", "MALIEV รับสแกน 3D ทั้งในสถานที่และนอกสถานที่ พร้อม Reverse Engineering, Deviation Analysis และไฟล์ส่งมอบตามการใช้งาน");
    ViewData["Keywords"] = T("3D scanning service Thailand, onsite 3D scanning, reverse engineering Thailand, deviation analysis, 3D scan price", "รับสแกน 3D, สแกน 3D ราคา, สแกน 3D นอกสถานที่, Reverse Engineering, Deviation Analysis");
    var faqJson = ThreeDimensionalScanningPage.CreateFaqJson();
}

@section Head {
    <link rel="preload" as="image" href="~/src/images/services/scanning/scanning-hero.webp" />
}

<component type="typeof(ThreeDimensionalScanningContent)" render-mode="Static" />

@section Schema { <component type="typeof(PublicServiceStructuredData)" render-mode="Static" param-Model="@(PublicServiceStructuredDataDisplayModel.Create("3D Scanning"))" /><script type="application/ld+json">@Html.Raw(faqJson)</script> }
