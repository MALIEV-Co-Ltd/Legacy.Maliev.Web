@page
@model Legacy.Maliev.Web.Pages.Account.IndexModel
@using Legacy.Maliev.Web.Components.Pages.Account
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<AccountIndexContent> AccountIndexLocalizer
@{ ViewData["Title"] = AccountIndexLocalizer["Member account | MALIEV"]; }
<main class="auth-page">
    <div class="maliev-container auth-shell">
        <section class="auth-intro">
            <p class="maliev-eyebrow">@AccountIndexLocalizer["Member workspace"]</p>
            <h1>@AccountIndexLocalizer["Manage manufacturing projects in one place"]</h1>
            <p>@AccountIndexLocalizer["Review quotations, orders, project files, and account details."]</p>
        </section>
        <section class="auth-card">
            <div class="auth-card__header"><h1>@AccountIndexLocalizer["Choose an account action"]</h1></div>
            <div class="maliev-actions">
                <component type="typeof(AccountIndexContent)" render-mode="Static" param-Model="Model.DisplayModel" />
                @if (Model.DisplayModel.IsAuthenticated)
                {
                    <form method="post" asp-page="/Account/Logout">
                        <button type="submit" class="maliev-button">@AccountIndexLocalizer["Sign out"]</button>
                    </form>
                }
            </div>
        </section>
    </div>
</main>
