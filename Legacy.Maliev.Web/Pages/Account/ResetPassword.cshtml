@page
@model Legacy.Maliev.Web.Pages.Account.ResetPassword
@using Legacy.Maliev.Web.Components.Pages.Account
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ResetPasswordContent> ResetPasswordLocalizer
@{ ViewData["Title"] = ResetPasswordLocalizer["Password Reset | MALIEV"]; ViewData["Robots"] = "noindex, nofollow"; }
<main class="auth-page"><div class="maliev-container auth-shell"><section class="auth-intro"><p class="maliev-eyebrow">@ResetPasswordLocalizer["Account security"]</p><h1>@ResetPasswordLocalizer["Create a new password"]</h1></section><section class="auth-card"><h1>@ResetPasswordLocalizer["Reset password"]</h1><form method="post" class="maliev-form"><component type="typeof(ResetPasswordContent)" render-mode="Static" param-Model="Model.DisplayModel" /></form></section></div></main>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
