@page
@model Legacy.Maliev.Web.Pages.Account.ResetPassword
@{ ViewData["Title"] = Localizer["Password Reset | MALIEV"]; ViewData["Robots"] = "noindex, nofollow"; }
<main class="auth-page"><div class="maliev-container auth-shell"><section class="auth-intro"><p class="maliev-eyebrow">@Localizer["Account security"]</p><h1>@Localizer["Create a new password"]</h1></section><section class="auth-card"><h1>@Localizer["Reset password"]</h1><form method="post" class="maliev-form"><div asp-validation-summary="All" class="validation-summary-errors" role="alert"></div><input type="hidden" asp-for="Email" /><input type="hidden" asp-for="Token" /><div class="maliev-form-field"><label asp-for="Password">@Localizer["New Password"]</label><input asp-for="Password" autocomplete="new-password" /><span asp-validation-for="Password"></span></div><div class="maliev-form-field"><label asp-for="ConfirmPassword">@Localizer["Retype Password"]</label><input asp-for="ConfirmPassword" autocomplete="new-password" /><span asp-validation-for="ConfirmPassword"></span></div><button type="submit" asp-page-handler="ChangePassword">@Localizer["Change Password"]</button></form></section></div></main>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
