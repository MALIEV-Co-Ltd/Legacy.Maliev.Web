@page
@model Legacy.Maliev.Web.Pages.Account.EmailConfirmation
@{ ViewData["Title"] = Localizer["Email Confirmation | MALIEV"]; ViewData["Robots"] = "noindex, nofollow"; }
<main class="maliev-page maliev-page-main"><div class="maliev-container"><section class="maliev-panel maliev-status"><p class="maliev-eyebrow">@Localizer["Email confirmation"]</p><h1>@Localizer["We could not confirm your email"]</h1><p>@Localizer["Request a new confirmation email or contact support."]</p><div asp-validation-summary="All" class="validation-summary-errors" role="alert"></div><a asp-page="/Account/Login" class="maliev-button">@Localizer["Back to sign in"]</a></section></div></main>
