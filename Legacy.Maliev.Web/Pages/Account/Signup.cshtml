@page
@model Legacy.Maliev.Web.Pages.Account.Signup
@{ ViewData["Title"] = Localizer["Sign Up | MALIEV"]; ViewData["Robots"] = "noindex, follow"; }
@section Head { <script src="https://www.google.com/recaptcha/enterprise.js?render=@Model.RecaptchaSiteKey"></script> }
<main class="auth-page">
    <div class="maliev-container auth-shell">
        <section class="auth-intro">
            <p class="maliev-eyebrow">MALIEV WORKSPACE</p>
            <h1>@Localizer["Manufacturing project management, in one place"]</h1>
            <p>@Localizer["Create an account to manage quotes, orders, projects, and files."]</p>
        </section>
        <section class="auth-card">
            <header class="auth-card__header"><h1>@Localizer["Join now"]</h1></header>
            @if (!string.IsNullOrWhiteSpace(Model.Notification))
            {
                <div class="maliev-alert maliev-alert--success" role="status">@Model.Notification</div>
            }
            <form id="customer-signup" method="post" class="maliev-form">
                <div asp-validation-summary="All" class="validation-summary-errors" role="alert"></div>
                <div class="maliev-form-grid">
                    <div class="maliev-form-field"><label asp-for="FirstName">@Localizer["First name"]</label><input asp-for="FirstName" autocomplete="given-name" /><span asp-validation-for="FirstName"></span></div>
                    <div class="maliev-form-field"><label asp-for="LastName">@Localizer["Last name"]</label><input asp-for="LastName" autocomplete="family-name" /><span asp-validation-for="LastName"></span></div>
                    <div class="maliev-form-field maliev-form-field--full"><label asp-for="Email">@Localizer["Email"]</label><input asp-for="Email" autocomplete="email" /><span asp-validation-for="Email"></span></div>
                    <div class="maliev-form-field"><label asp-for="Password">@Localizer["Password"]</label><input asp-for="Password" autocomplete="new-password" /><span asp-validation-for="Password"></span></div>
                    <div class="maliev-form-field"><label asp-for="ConfirmPassword">@Localizer["Retype Password"]</label><input asp-for="ConfirmPassword" autocomplete="new-password" /><span asp-validation-for="ConfirmPassword"></span></div>
                </div>
                <input type="hidden" asp-for="RecaptchaToken" />
                <p>@Localizer["By signing up, you agree to our"] <a asp-page="/Legal/TermsConditions">@Localizer["Terms and Conditions"]</a> @Localizer["and"] <a asp-page="/Legal/PrivacyPolicy">@Localizer["Privacy Policy"]</a>.</p>
                <button type="submit" asp-page-handler="SignUp" id="submit-button">@Localizer["Sign Up"]</button>
            </form>
            <footer class="auth-card__footer">@Localizer["Already have an account?"] <a asp-page="/Account/Login">@Localizer["Sign in"]</a></footer>
        </section>
    </div>
</main>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('customer-signup').addEventListener('submit', function (event) {
            if (this.dataset.verified === 'true') return;
            event.preventDefault();
            grecaptcha.enterprise.ready(() => grecaptcha.enterprise.execute('@Model.RecaptchaSiteKey', { action: 'account_signup' }).then(token => {
                document.getElementById('RecaptchaToken').value = token;
                this.dataset.verified = 'true';
                this.submit();
            }));
        });
    </script>
}
