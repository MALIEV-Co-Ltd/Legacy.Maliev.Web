@page
@model Legacy.Maliev.Web.Pages.Account.Signup
@using Legacy.Maliev.Web.Components.Pages.Account
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SignupContent> SignupLocalizer
@{ ViewData["Title"] = SignupLocalizer["Sign Up | MALIEV"]; ViewData["Robots"] = "noindex, follow"; }
@section Head { <script src="https://www.google.com/recaptcha/enterprise.js?render=@Model.RecaptchaSiteKey"></script> }
<main class="auth-page">
    <div class="maliev-container auth-shell">
        <section class="auth-intro">
            <p class="maliev-eyebrow">MALIEV WORKSPACE</p>
            <h1>@SignupLocalizer["Manufacturing project management, in one place"]</h1>
            <p>@SignupLocalizer["Create an account to manage quotes, orders, projects, and files."]</p>
        </section>
        <section class="auth-card">
            <header class="auth-card__header"><h1>@SignupLocalizer["Join now"]</h1></header>
            @if (!string.IsNullOrWhiteSpace(Model.Notification))
            {
                <div class="maliev-alert maliev-alert--success" role="status">@Model.Notification</div>
            }
            <form id="customer-signup" method="post" class="maliev-form">
                <component type="typeof(SignupContent)" render-mode="Static" param-Model="Model.DisplayModel" />
            </form>
            <footer class="auth-card__footer">@SignupLocalizer["Already have an account?"] <a href="/Account/Login">@SignupLocalizer["Sign in"]</a></footer>
        </section>
    </div>
</main>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.getElementById('customer-signup').addEventListener('submit', function (event) {
            if (this.dataset.verified === 'true') return;
            event.preventDefault();
            grecaptcha.enterprise.ready(() => grecaptcha.enterprise.execute('@Model.RecaptchaSiteKey', { action: 'account_signup' }).then(token => {
                document.getElementById('signup-recaptcha-response').value = token;
                this.dataset.verified = 'true';
                this.submit();
            }));
        });
    </script>
}
