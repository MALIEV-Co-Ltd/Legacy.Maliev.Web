@page
@model Legacy.Maliev.Web.Pages.Account.Login
@using Legacy.Maliev.Web.Components.Pages.Account
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<LoginContent> LoginLocalizer
@{ ViewData["Title"] = LoginLocalizer["Login | MALIEV"]; ViewData["Robots"] = "noindex, follow"; }
<main class="auth-page">
    <div class="maliev-container auth-shell">
        <section class="auth-intro">
            <p class="maliev-eyebrow">MALIEV WORKSPACE</p>
            <h1>@LoginLocalizer["Manage your manufacturing projects"]</h1>
            <p>@LoginLocalizer["Sign in to review quotations, orders, files, and account details in one secure place."]</p>
        </section>
        <section class="auth-card">
            <header class="auth-card__header"><h1>@LoginLocalizer["Sign in"]</h1></header>
            <form method="post" class="maliev-form">
                <component type="typeof(LoginContent)" render-mode="Static" param-Model="Model.DisplayModel" />
            </form>
            <footer class="auth-card__footer">
                <a href="/Account/Signup">@LoginLocalizer["Create your account"]</a>
                <a href="/Account/ForgotPassword">@LoginLocalizer["Forgot your password?"]</a>
            </footer>
        </section>
    </div>
</main>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
