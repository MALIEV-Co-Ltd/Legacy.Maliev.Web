@page
@model Legacy.Maliev.Web.Pages.Account.ForgotPassword
@using Legacy.Maliev.Web.Components.Pages.Account
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ForgotPasswordContent> ForgotPasswordLocalizer
@{ ViewData["Title"] = ForgotPasswordLocalizer["Forgot Password | MALIEV"]; ViewData["Robots"] = "noindex, nofollow"; }
<main class="auth-page">
    <div class="maliev-container auth-shell">
        <section class="auth-intro"><p class="maliev-eyebrow">@ForgotPasswordLocalizer["Account recovery"]</p><h1>@ForgotPasswordLocalizer["Return to your workspace"]</h1><p>@ForgotPasswordLocalizer["Enter your email address and we will send a secure reset link if the account is eligible."]</p></section>
        <section class="auth-card">
            <h1>@ForgotPasswordLocalizer["Forgot password"]</h1>
            <form method="post" class="maliev-form">
                <component type="typeof(ForgotPasswordContent)" render-mode="Static" param-Model="Model.DisplayModel" />
            </form>
            <footer class="auth-card__footer"><a href="/Account/Login">@ForgotPasswordLocalizer["Back to sign in"]</a></footer>
        </section>
    </div>
</main>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
