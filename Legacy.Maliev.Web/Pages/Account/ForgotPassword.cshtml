@page
@model Legacy.Maliev.Web.Pages.Account.ForgotPassword
@{ ViewData["Title"] = Localizer["Forgot Password | MALIEV"]; ViewData["Robots"] = "noindex, nofollow"; }
<main class="auth-page">
    <div class="maliev-container auth-shell">
        <section class="auth-intro"><p class="maliev-eyebrow">@Localizer["Account recovery"]</p><h1>@Localizer["Return to your workspace"]</h1><p>@Localizer["Enter your email address and we will send a secure reset link if the account is eligible."]</p></section>
        <section class="auth-card">
            <h1>@Localizer["Forgot password"]</h1>
            @if (!string.IsNullOrWhiteSpace(Model.Notification)) { <div class="maliev-alert" role="status">@Model.Notification</div> }
            <form method="post" class="maliev-form">
                <div asp-validation-summary="All" class="validation-summary-errors" role="alert"></div>
                <div class="maliev-form-field"><label asp-for="Email">@Localizer["Email"]</label><input asp-for="Email" autocomplete="email" /><span asp-validation-for="Email"></span></div>
                <button type="submit" asp-page-handler="PasswordReset">@Localizer["Reset password"]</button>
            </form>
            <footer class="auth-card__footer"><a asp-page="/Account/Login">@Localizer["Back to sign in"]</a></footer>
        </section>
    </div>
</main>
@section Scripts { <partial name="_ValidationScriptsPartial" /> }
