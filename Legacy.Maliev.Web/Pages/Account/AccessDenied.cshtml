@page
@model Legacy.Maliev.Web.Pages.Account.AccessDenied
@{ ViewData["Title"] = Localizer["Access denied | MALIEV"]; ViewData["Robots"] = "noindex, nofollow"; }
<main class="maliev-page maliev-page-main">
    <div class="maliev-container">
        <section class="maliev-panel maliev-status">
            <p class="maliev-eyebrow">@Localizer["Account access"]</p>
            <h1>@Localizer["Access denied"]</h1>
            <p>@Localizer["You are not authorized to see this content"]</p>
            <div class="maliev-actions">
                <a asp-page="/Index" class="maliev-button">@Localizer["Back to the home page"]</a>
                <a asp-page="/Contact/Index" class="maliev-button maliev-button--secondary">@Localizer["Contact support"]</a>
            </div>
        </section>
    </div>
</main>
