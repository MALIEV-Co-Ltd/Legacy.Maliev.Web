@page
@model Legacy.Maliev.Web.Pages.ErrorModel
@using Legacy.Maliev.Web.Components.Pages
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ErrorContent> ErrorLocalizer
@{
    ViewData["Title"] = ErrorLocalizer["Error | MALIEV"];
    ViewData["Robots"] = "noindex,nofollow";
    ViewData["SuppressIdentityNavigation"] = true;
}
<component type="typeof(ErrorContent)" render-mode="Static" param-Model="Model.DisplayModel" />
