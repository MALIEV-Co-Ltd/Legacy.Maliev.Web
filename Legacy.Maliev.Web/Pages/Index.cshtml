@page
@model IndexModel
@{
    Layout = "_Layout";
    string keywordResult;
    if (System.Threading.Thread.CurrentThread.CurrentCulture.TwoLetterISOLanguageName == "th")
    {
        ViewData["Title"] = "บริการผลิตชิ้นส่วนออนไลน์ นนทบุรี กรุงเทพ: CNC, พิมพ์ 3 มิติ, สแกน 3 มิติ";
        ViewData["Description"] = "บริการพิมพ์ 3 มิติ ชิ้นงาน CNC และสแกน 3 มิติ ในนนทบุรีและกรุงเทพ อัปโหลดไฟล์เพื่อประเมินราคาทันที ไม่มีจำนวนขั้นต่ำ";
        keywordResult = "รับปริ้น 3D, รับพิมพ์ 3 มิติ, รับสแกน 3D, รับ CNC ตามแบบ, โรงกลึง นนทบุรี, CNC กรุงเทพ";
    }
    else
    {
        ViewData["Title"] = "Manufacturing Services Bangkok Nonthaburi: CNC Machining, 3D Printing & 3D Scanning";
        ViewData["Description"] = "Professional CNC machining, 3D printing, and 3D scanning services in Bangkok and Nonthaburi, Thailand. Upload your file for an instant quote.";
        keywordResult = "3d printing thailand, 3d scanning thailand, cnc machining thailand, manufacturing services bangkok, cnc machining nonthaburi";
    }

    ViewData["Keywords"] = keywordResult;
}

@section Head {
    <link rel="stylesheet" href="~/src/app/css/landing.css" asp-append-version="true" />
}

<section class="landing-hero" aria-labelledby="landing-hero-title">
    <div class="landing-container landing-hero-grid">
        <div class="landing-hero-copy">
            <p class="landing-eyebrow">@Localizer["Precision. Speed. Reliability."]</p>
            <h1 id="landing-hero-title">@Localizer["Manufacturing Services for Prototypes and Production Parts"]</h1>
            <p class="landing-hero-lead">@Localizer["CNC machining, 3D printing, and 3D scanning under one roof. From rapid prototypes to end-use parts, we deliver precision manufacturing solutions that help you bring ideas to life faster."]</p>
            <div class="landing-actions">
                <a class="landing-button landing-button-primary" asp-page="/InstantQuotation/3D-Printing">@Localizer["Instant 3D Quotation"] <i class="fas fa-arrow-right" aria-hidden="true"></i></a>
                <a class="landing-button landing-button-secondary" asp-page="/Contact/Index">@Localizer["Talk to Us"] <i class="far fa-comment-dots" aria-hidden="true"></i></a>
            </div>
            <p class="landing-trust"><i class="fas fa-shield-alt" aria-hidden="true"></i> @Localizer["Secure. Confidential. Trusted by engineers and product teams."]</p>
        </div>
        <div class="landing-hero-media" aria-label="@Localizer["CNC machining, 3D printing, and 3D scanning"]">
            <figure class="landing-collage landing-collage-cnc"><img src="~/src/images/landing/landing-hero-cnc.webp" alt="@Localizer["Precision CNC machining"]" /></figure>
            <figure class="landing-collage landing-collage-print"><img src="~/src/images/landing/landing-hero-printing.webp" alt="@Localizer["Industrial 3D printing"]" /></figure>
            <figure class="landing-collage landing-collage-scan"><img src="~/src/images/landing/landing-hero-scanning.webp" alt="@Localizer["High-accuracy 3D scanning"]" /></figure>
        </div>
    </div>
</section>

<section class="landing-value-wrap" aria-label="@Localizer["Why customers work with MALIEV"]">
    <div class="landing-container landing-value-strip">
        <article><i class="fas fa-bolt" aria-hidden="true"></i><div><h2>@Localizer["Fast & Competitive Quotes"]</h2><p>@Localizer["Get an accurate quote in hours, not days."]</p></div></article>
        <article><i class="fas fa-cube" aria-hidden="true"></i><div><h2>@Localizer["Multiple Manufacturing Methods"]</h2><p>@Localizer["CNC machining, 3D printing, and 3D scanning solutions."]</p></div></article>
        <article><i class="far fa-user" aria-hidden="true"></i><div><h2>@Localizer["Engineering Support"]</h2><p>@Localizer["Expert guidance to optimize designs and reduce costs."]</p></div></article>
        <article><i class="far fa-clock" aria-hidden="true"></i><div><h2>@Localizer["Reliable Lead Times"]</h2><p>@Localizer["Clear production schedules you can count on."]</p></div></article>
    </div>
</section>

<section id="landing-services" class="landing-section" aria-labelledby="landing-services-title">
    <div class="landing-container">
        <header class="landing-section-heading"><p>@Localizer["Our Services"]</p><h2 id="landing-services-title">@Localizer["Precision Manufacturing Solutions"]</h2><span>@Localizer["End-to-end services for every stage of product development and production."]</span></header>
        <div class="landing-service-grid">
            <article class="landing-service-card"><img src="~/src/images/landing/landing-service-cnc.webp" alt="@Localizer["CNC-machined metal component"]" /><div><span class="landing-card-icon"><i class="fas fa-drafting-compass" aria-hidden="true"></i></span><h3>@Localizer["CNC Machining"]</h3><p>@Localizer["High-precision machining for metals and plastics with tight tolerances and excellent surface finishes."]</p><a asp-page="/Services/CNC-Machining">@Localizer["Learn more"] <i class="fas fa-arrow-right" aria-hidden="true"></i></a></div></article>
            <article class="landing-service-card"><img src="~/src/images/landing/landing-service-printing.webp" alt="@Localizer["Intricate 3D-printed component"]" /><div><span class="landing-card-icon"><i class="fas fa-print" aria-hidden="true"></i></span><h3>@Localizer["3D Printing"]</h3><p>@Localizer["Fast, flexible additive manufacturing for prototypes and functional parts in a variety of materials."]</p><a asp-page="/Services/3D-Printing">@Localizer["Learn more"] <i class="fas fa-arrow-right" aria-hidden="true"></i></a></div></article>
            <article class="landing-service-card"><img src="~/src/images/landing/landing-service-scanning.webp" alt="@Localizer["3D scanning a mechanical component"]" /><div><span class="landing-card-icon"><i class="fas fa-cubes" aria-hidden="true"></i></span><h3>@Localizer["3D Scanning"]</h3><p>@Localizer["High-accuracy scanning for reverse engineering, inspection, and quality control."]</p><a asp-page="/Services/3D-Scanning">@Localizer["Learn more"] <i class="fas fa-arrow-right" aria-hidden="true"></i></a></div></article>
        </div>
    </div>
</section>

<section id="landing-process" class="landing-section landing-process" aria-labelledby="landing-process-title">
    <div class="landing-container">
        <header class="landing-section-heading"><p>@Localizer["How It Works"]</p><h2 id="landing-process-title">@Localizer["Simple. Fast. Reliable."]</h2></header>
        <ol class="landing-process-grid">
            <li><span class="landing-step-number">1</span><div class="landing-step-icon"><i class="fas fa-upload" aria-hidden="true"></i></div><h3>@Localizer["Upload CAD files"]</h3><p>@Localizer["Submit your CAD files and project details through our secure portal."]</p></li>
            <li><span class="landing-step-number">2</span><div class="landing-step-icon"><i class="far fa-file-alt" aria-hidden="true"></i></div><h3>@Localizer["Review quotation"]</h3><p>@Localizer["Receive a detailed quote with price, lead time, and engineering feedback."]</p></li>
            <li><span class="landing-step-number">3</span><div class="landing-step-icon"><i class="far fa-check-circle" aria-hidden="true"></i></div><h3>@Localizer["Confirm order"]</h3><p>@Localizer["Approve the quote and we will start manufacturing your parts."]</p></li>
            <li><span class="landing-step-number">4</span><div class="landing-step-icon"><i class="fas fa-box" aria-hidden="true"></i></div><h3>@Localizer["Receive parts"]</h3><p>@Localizer["Parts are quality-checked and delivered safely to your doorstep."]</p></li>
        </ol>
    </div>
</section>

<section id="landing-reasons" class="landing-section landing-reasons" aria-labelledby="landing-reasons-title">
    <div class="landing-container">
        <header class="landing-section-heading"><p>@Localizer["Why Choose MALIEV"]</p><h2 id="landing-reasons-title">@Localizer["Built for Quality. Driven by Engineering."]</h2></header>
        <div class="landing-reason-grid">
            <article><i class="fas fa-award" aria-hidden="true"></i><div><h3>@Localizer["Prototype to Production"]</h3><p>@Localizer["From one-off prototypes to full-scale production, we grow with your project."]</p></div></article>
            <article><i class="far fa-user" aria-hidden="true"></i><div><h3>@Localizer["Engineering Support"]</h3><p>@Localizer["DFM analysis and practical advice improve your design and outcomes."]</p></div></article>
            <article><i class="fas fa-shield-alt" aria-hidden="true"></i><div><h3>@Localizer["Quality-Focused"]</h3><p>@Localizer["Strict quality control and careful inspection deliver consistent results."]</p></div></article>
            <article><i class="far fa-comments" aria-hidden="true"></i><div><h3>@Localizer["Responsive Communication"]</h3><p>@Localizer["Real people, clear updates, and practical support when you need us."]</p></div></article>
        </div>
    </div>
</section>

<section class="landing-cta-section">
    <div class="landing-container landing-cta">
        <div><h2>@Localizer["Ready to bring your ideas to life?"]</h2><p>@Localizer["Get a fast, accurate 3D printing estimate for your project today."]</p><div class="landing-actions"><a class="landing-button landing-button-yellow" asp-page="/InstantQuotation/3D-Printing">@Localizer["Instant 3D Quotation"] <i class="fas fa-arrow-right" aria-hidden="true"></i></a><a class="landing-button landing-button-light" asp-page="/Contact/Index">@Localizer["Talk to an Expert"]</a></div></div>
        <ul><li><i class="fas fa-check-circle" aria-hidden="true"></i> @Localizer["Fast response"]</li><li><i class="fas fa-check-circle" aria-hidden="true"></i> @Localizer["Competitive pricing"]</li><li><i class="fas fa-check-circle" aria-hidden="true"></i> @Localizer["Confidential and secure"]</li></ul>
        <img src="~/src/images/landing/landing-cta-part.webp" alt="@Localizer["Precision-machined aluminum component"]" />
    </div>
</section>
