@page
@model Legacy.Maliev.Web.Pages.Legal.TermModel
@using Legacy.Maliev.Web.Components.Pages.Legal
@{
    string keywordResult = string.Empty;
    if (System.Threading.Thread.CurrentThread.CurrentCulture.TwoLetterISOLanguageName == "th")
    {
        ViewData["Title"] = "ข้อกำหนดและเงื่อนไขการให้บริการ | MALIEV";
        ViewData["Description"] = "ข้อกำหนดและเงื่อนไขการเก็บข้อมูลและใช้บริการต่างๆของเรา";
        List<string> keywords = new List<string>()
{
"นโยบายความเป็นส่วนตัว",
"cookies",
"license",
"hyperlink",
"terms",
"services",
"iframes",
"rights",
"liability",
"disclaimer",
};
        keywordResult = String.Join(", ", keywords.ToArray());
    }
    else
    {
        ViewData["Title"] = "Terms and Conditions | MALIEV";
        ViewData["Description"] = "These terms and conditions outline the rules and regulations for the use of Maliev Co., Ltd.'s Website.";
        List<string> keywords = new List<string>()
{
"cookies",
"license",
"hyperlink",
"terms and conditions",
"terms",
"services",
"iframes",
"rights",
"liability",
"disclaimer",
};
        keywordResult = String.Join(", ", keywords.ToArray());
    }

    ViewData["Keywords"] = keywordResult;
}
<component type="typeof(TermsConditionsContent)" render-mode="Static" />
