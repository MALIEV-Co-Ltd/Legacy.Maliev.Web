@page
@model Legacy.Maliev.Web.Pages.Legal.NonDisclosureAgreementModel
@{
    string keywordResult = string.Empty;
    if (System.Threading.Thread.CurrentThread.CurrentCulture.TwoLetterISOLanguageName == "th")
    {
        ViewData["Title"] = "สัญญาปกปิดความลับ | MALIEV";
        ViewData["Description"] = "เราให้ความสำคัญกับความลับของชิ้นงานอยู่มากที่สุด คุณสามารถขอสัญญาปกปิดความลับได้ที่นี่";
        List<string> keywords = new List<string>()
{
"สัญญาปกปิดความลับ",
};
        keywordResult = String.Join(", ", keywords.ToArray());
    }
    else
    {
        ViewData["Title"] = "Non-Disclosure Agreement | MALIEV";
        ViewData["Description"] = "Your confidentiality at the Maliev is of the utmost importance.";
        List<string> keywords = new List<string>()
{
"non-disclosure agreement",
"confidential agreement",
};
        keywordResult = String.Join(", ", keywords.ToArray());
    }

    ViewData["Keywords"] = keywordResult;
}

@using Legacy.Maliev.Web.Components.Pages.Legal

<component type="typeof(NonDisclosureAgreementContent)" render-mode="Static" />
