@page
@model AboutModel
@using Legacy.Maliev.Web.Components.Pages.About
@{
    if (System.Threading.Thread.CurrentThread.CurrentCulture.TwoLetterISOLanguageName == "th")
    {
        ViewData["Title"] = "เกี่ยวกับ MALIEV | ระบบการผลิตที่เชื่อมต่อกันในประเทศไทย";
        ViewData["Description"] = "ติดตามเส้นทางที่มีหลักฐานของ MALIEV จากเวิร์กช็อปครอบครัวในนนทบุรี สู่บริการ CNC พิมพ์ 3 มิติ และสแกน 3 มิติที่เชื่อมต่อกัน";
        ViewData["Keywords"] = "ประวัติ MALIEV, บริษัทผลิตชิ้นส่วน, CNC นนทบุรี, พิมพ์ 3 มิติ, สแกน 3 มิติ";
    }
    else
    {
        ViewData["Title"] = "About MALIEV | Connected manufacturing in Thailand";
        ViewData["Description"] = "Follow MALIEV's documented journey from a family workshop in Nonthaburi to connected CNC machining, 3D printing, and 3D scanning services.";
        ViewData["Keywords"] = "MALIEV history, manufacturing company Thailand, CNC Nonthaburi, 3D printing Thailand, 3D scanning Thailand";
    }

}
<component type="typeof(AboutContent)" render-mode="Static" />
