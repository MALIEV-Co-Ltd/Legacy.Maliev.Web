@page
@model Legacy.Maliev.Web.Areas.Member.Pages.Orders.Index
@{
    ViewData["Title"] = Localizer["Orders | MALIEV"];
    ViewData["Robots"] = "noindex,follow";
}

<section class="maliev-section">
    <p class="maliev-eyebrow">@Localizer["Order management"]</p>
    <h1>@Localizer["Start or review an order"]</h1>
    <div class="maliev-card-grid">
        <a class="maliev-panel" asp-area="" asp-page="/Quotation/Index" asp-route-item="CNC-Machining"><strong>@Localizer["CNC machining"]</strong></a>
        <a class="maliev-panel" asp-area="" asp-page="/Quotation/Index" asp-route-item="3D-Printing"><strong>@Localizer["3D printing"]</strong></a>
        <a class="maliev-panel" asp-area="" asp-page="/Quotation/Index" asp-route-item="3D-Scanning"><strong>@Localizer["3D scanning"]</strong></a>
    </div>
</section>
