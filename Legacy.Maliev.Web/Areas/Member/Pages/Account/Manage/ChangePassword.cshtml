@page
@model Legacy.Maliev.Web.Areas.Member.Pages.Account.Manage.ChangePassword
@inject IStringLocalizer<MemberChangePasswordContent> MetadataLocalizer
@{
    ViewData["Title"] = MetadataLocalizer["Change password | MALIEV"];
    ViewData["Robots"] = "noindex,follow";
}
<section class="maliev-section" aria-labelledby="member-change-password-title">
    <form method="post" asp-page-handler="ChangePassword" class="maliev-panel maliev-form">
        <component type="typeof(MemberChangePasswordContent)" render-mode="Static" param-Model="Model.DisplayModel" />
    </form>
</section>
