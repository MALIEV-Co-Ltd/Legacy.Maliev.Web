@page
@model Legacy.Maliev.Web.Areas.Member.Pages.Account.Manage.ChangePassword
@{
    ViewData["Title"] = Localizer["Change password | MALIEV"];
    ViewData["Robots"] = "noindex,follow";
}
<section class="maliev-section">
    <div class="maliev-section-header">
        <p class="maliev-eyebrow">@Localizer["Customer account"]</p>
        <h1>@Localizer["Change password"]</h1>
        <p>@Localizer["All signed-in sessions will be revoked after this change."]</p>
    </div>
    <form method="post" asp-page-handler="ChangePassword" class="maliev-panel maliev-form">
        <div asp-validation-summary="All" class="field-validation-error" role="alert"></div>
        <div class="maliev-form-field"><label asp-for="CurrentPassword"></label><input asp-for="CurrentPassword" autocomplete="current-password" /></div>
        <div class="maliev-form-field"><label asp-for="NewPassword"></label><input asp-for="NewPassword" autocomplete="new-password" /></div>
        <div class="maliev-form-field"><label asp-for="ConfirmPassword"></label><input asp-for="ConfirmPassword" autocomplete="new-password" /></div>
        <button type="submit" class="maliev-button">@Localizer["Change password"]</button>
    </form>
</section>
