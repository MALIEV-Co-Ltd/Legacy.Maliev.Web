@page
@model Legacy.Maliev.Web.Areas.Member.Pages.Account.Manage.Address
@inject IStringLocalizer<MemberAddressContent> MetadataLocalizer
@{
    ViewData["Title"] = MetadataLocalizer["Addresses | MALIEV"];
    ViewData["Robots"] = "noindex,follow";
}

<section class="maliev-section" aria-labelledby="member-address-title">
    <form method="post" asp-page-handler="UpdateAddress" class="maliev-panel">
        <component type="typeof(MemberAddressContent)" render-mode="Static" param-Model="Model.DisplayModel" />
    </form>
</section>
