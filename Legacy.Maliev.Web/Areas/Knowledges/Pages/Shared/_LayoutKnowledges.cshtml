@using Legacy.Maliev.Web.Components.Layout
<!DOCTYPE html>
<html lang="@System.Threading.Thread.CurrentThread.CurrentCulture.TwoLetterISOLanguageName">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <meta name="description" content="@ViewData["Description"]" />
    <meta name="keywords" content="@ViewData["Keywords"]" />
    <meta name="author" content="Maliev Company Limited" />
    <meta name="language" content="@System.Threading.Thread.CurrentThread.CurrentUICulture.TwoLetterISOLanguageName" />
    <meta name="robots" content="index,follow" />
    <meta property="og:title" content="@ViewData["Title"]" />
    <meta property="og:description" content="@ViewData["Description"]" />
    @RenderSection("Meta", required: false)
    <title>@ViewData["Title"]</title>
    <partial name="_CssPartial" />
    <partial name="_FontPartial" />
    <partial name="_GoogleTagManagerPartial" />
    <component type="typeof(PublicDocumentLinks)" render-mode="Static" param-Model="@(PublicDocumentLinksDisplayModel.Create(Context))" />
</head>
<body>
    <a class="maliev-skip-link" href="#knowledge-content">@Localizer["Skip to main content"]</a>
    <partial name="_GoogleTagManagerBodyPartial" />
    <component type="typeof(PublicCookieConsent)" render-mode="Static" param-Model="@(PublicCookieConsentDisplayModel.Create(Context))" />
    <component type="typeof(PublicNavigation)" render-mode="Static" param-Model="@(PublicNavigationDisplayModel.Create(Context, ViewData["SuppressIdentityNavigation"] is true))" />
    <div class="docs-page">
        <div class="workspace-shell docs-shell">
            <partial name="_SidebarPartial" />
            <main id="knowledge-content" class="docs-content" tabindex="-1">
                <div class="workspace-toolbar">
                    <button type="button" class="workspace-drawer-toggle" aria-controls="knowledge-navigation" aria-expanded="false" data-workspace-open><i class="fas fa-bars" aria-hidden="true"></i> <span>@Localizer["Contents"]</span></button>
                </div>
                @RenderBody()
            </main>
        </div>
        <button type="button" class="workspace-backdrop" data-workspace-backdrop hidden aria-label="@Localizer["Close contents"]"></button>
    </div>
    <component type="typeof(PublicFooter)" render-mode="Static" />
    <partial name="_Go2TopPartial" />
    <partial name="_ContactChannelAnalyticsPartial" />
    <partial name="_JavaScriptsPartial" />
    <script>
        (() => {
            const drawer = document.getElementById('knowledge-navigation');
            const openButton = document.querySelector('[data-workspace-open]');
            const closeButton = drawer?.querySelector('[data-workspace-close]');
            const backdrop = document.querySelector('[data-workspace-backdrop]');
            if (!drawer || !openButton || !backdrop) return;
            const close = () => { drawer.classList.remove('is-open'); document.body.classList.remove('workspace-drawer-open'); openButton.setAttribute('aria-expanded', 'false'); backdrop.hidden = true; openButton.focus(); };
            const open = () => { drawer.classList.add('is-open'); document.body.classList.add('workspace-drawer-open'); openButton.setAttribute('aria-expanded', 'true'); backdrop.hidden = false; closeButton?.focus(); };
            openButton.addEventListener('click', open);
            closeButton?.addEventListener('click', close);
            backdrop.addEventListener('click', close);
            document.addEventListener('keydown', event => { if (event.key === 'Escape' && drawer.classList.contains('is-open')) close(); });
        })();
    </script>
    @RenderSection("Scripts", required: false)
</body>
</html>
